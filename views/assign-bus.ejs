<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assign Bus | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <h3 class="mb-3"><i class="bi bi-signpost-split"></i> Assign Bus &amp; Driver</h3>

      <div class="row g-3">
        <!-- Assign bus to student -->
        <div class="col-lg-6">
          <div class="card p-4">
            <h5><i class="bi bi-person-check"></i> Assign Bus to Student</h5>
            <form action="/admin/assign-bus/student" method="POST" class="mt-3">
              <div class="mb-3">
                <label class="form-label">Select Student</label>
                <select name="student_id" class="form-select" required>
                  <option value="" disabled selected>-- Choose Student --</option>
                  <% students.forEach(s => { %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.roll_no %>)<%= s.bus_number ? ' — currently: ' + s.bus_number : '' %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Select Bus</label>
                <select name="bus_id" class="form-select" required>
                  <option value="">-- Remove from bus --</option>
                  <% buses.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.bus_number %> — <%= b.route_name %></option>
                  <% }) %>
                </select>
              </div>
              <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Assign</button>
            </form>
          </div>
        </div>

        <!-- Assign driver to bus -->
        <div class="col-lg-6">
          <div class="card p-4">
            <h5><i class="bi bi-person-badge"></i> Assign Driver to Bus</h5>
            <form action="/admin/assign-bus/driver" method="POST" class="mt-3">
              <div class="mb-3">
                <label class="form-label">Select Bus</label>
                <select name="bus_id" class="form-select" required>
                  <option value="" disabled selected>-- Choose Bus --</option>
                  <% buses.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.bus_number %> — <%= b.route_name %><%= b.driver_name ? ' — currently: ' + b.driver_name : '' %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Select Driver</label>
                <select name="driver_id" class="form-select" required>
                  <option value="">-- Remove driver --</option>
                  <% drivers.forEach(d => { %>
                    <option value="<%= d.id %>"><%= d.name %></option>
                  <% }) %>
                </select>
              </div>
              <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Assign</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Current assignments overview -->
      <div class="card p-3 mt-4">
        <h5 class="mb-3"><i class="bi bi-list-check"></i> Current Bus Assignments</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Bus</th>
                <th>Route</th>
                <th>Driver</th>
                <th>Students Assigned</th>
              </tr>
            </thead>
            <tbody>
              <% buses.forEach(b => { %>
                <tr>
                  <td><strong><%= b.bus_number %></strong></td>
                  <td><%= b.route_name %></td>
                  <td><%= b.driver_name || '—' %></td>
                  <td><%= students.filter(s => s.bus_id === b.id).length %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

       
    </div>
  </div>
  <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
