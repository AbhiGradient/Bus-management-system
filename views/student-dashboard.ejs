<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/student/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Student</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link active" href="/student/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/student/requests"><i class="bi bi-envelope-paper"></i> My Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/student/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/student/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <h3 class="mb-1">Welcome, <%= user.name %> 👋</h3>
      <p class="text-muted">
        <% if (student) { %>Roll No: <strong><%= student.roll_no %></strong> · <%= student.department || '' %> <%= student.year || '' %><% } %>
      </p>

      <div class="row g-3 mt-2">
        <div class="col-md-6">
          <div class="card p-4 h-100">
            <h5><i class="bi bi-bus-front-fill text-primary"></i> My Bus</h5>
            <% if (bus) { %>
              <hr />
              <p class="mb-1"><strong>Bus Number:</strong> <%= bus.bus_number %></p>
              <p class="mb-1"><strong>Route:</strong> <%= bus.route_name %></p>
              <p class="mb-1"><strong>Driver:</strong> <%= bus.driver_name || 'Not assigned yet' %></p>
              <p class="mb-0"><strong>Driver Contact:</strong> <%= bus.driver_phone || '—' %></p>
            <% } else { %>
              <p class="text-muted mt-3">No bus has been assigned to you yet. Please contact the administration.</p>
            <% } %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card p-4 h-100">
            <h5><i class="bi bi-cash-coin text-warning"></i> Fee Status</h5>
            <hr />
            <% if (feeSummary && feeSummary.unpaidCount > 0) { %>
              <p class="text-danger">You have <strong><%= feeSummary.unpaidCount %></strong> unpaid fee record(s).</p>
            <% } else { %>
              <p class="text-success">All your transport fees are paid. 🎉</p>
            <% } %>
            <a href="/student/fees" class="btn btn-outline-primary btn-sm mt-2">View Fee Details</a>
          </div>
        </div>
      </div>

      <div class="card p-4 mt-3">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-envelope-paper text-secondary"></i> Recent Requests</h5>
          <a href="/student/requests" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> New Request</a>
        </div>
        <hr />
        <% if (recentRequests.length === 0) { %>
          <p class="text-muted mb-0">You haven't submitted any requests yet.</p>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% recentRequests.forEach(r => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= r.subject %></span>
                <span class="badge badge-status
                  <%= r.status === 'approved' ? 'bg-success' : r.status === 'rejected' ? 'bg-danger' : 'bg-warning text-dark' %>">
                  <%= r.status %>
                </span>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <footer class="app-footer">Smart College Bus Management System &copy; <%= new Date().getFullYear() %></footer>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
