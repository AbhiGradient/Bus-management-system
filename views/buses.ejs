<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Buses | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-bus-front-fill"></i> Manage Buses</h3>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addBusModal">
          <i class="bi bi-plus-circle"></i> Add Bus
        </button>
      </div>

      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Bus Number</th>
                <th>Route</th>
                <th>Capacity</th>
                <th>Driver</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (buses.length === 0) { %>
                <tr><td colspan="7" class="text-center text-muted py-3">No buses added yet.</td></tr>
              <% } %>
              <% buses.forEach((bus, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= bus.bus_number %></strong></td>
                  <td><%= bus.route_name %></td>
                  <td><%= bus.capacity %></td>
                  <td><%= bus.driver_name || '—' %></td>
                  <td>
                    <span class="badge badge-status <%= bus.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                      <%= bus.status %>
                    </span>
                  </td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editBusModal<%= bus.id %>">
                      <i class="bi bi-pencil-square"></i>
                    </button>
                    <form action="/admin/buses/<%= bus.id %>?_method=DELETE" method="POST" class="d-inline confirm-delete">
                      <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  </td>
                </tr>

                <!-- Edit Modal -->
                <div class="modal fade" id="editBusModal<%= bus.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <form action="/admin/buses/<%= bus.id %>?_method=PUT" method="POST" class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Bus - <%= bus.bus_number %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <div class="modal-body">
                        <div class="mb-2">
                          <label class="form-label">Bus Number</label>
                          <input type="text" name="bus_number" class="form-control" value="<%= bus.bus_number %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Route</label>
                          <input type="text" name="route_name" class="form-control" value="<%= bus.route_name %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Capacity</label>
                          <input type="number" name="capacity" class="form-control" value="<%= bus.capacity %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Driver</label>
                          <select name="driver_id" class="form-select">
                            <option value="">-- Unassigned --</option>
                            <% drivers.forEach(d => { %>
                              <option value="<%= d.id %>" <%= bus.driver_id === d.id ? 'selected' : '' %>><%= d.name %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Status</label>
                          <select name="status" class="form-select">
                            <option value="active" <%= bus.status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= bus.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                          </select>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                      </div>
                    </form>
                  </div>
                </div>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <footer class="app-footer">Smart College Bus Management System &copy; <%= new Date().getFullYear() %></footer>
    </div>
  </div>

  <!-- Add Bus Modal -->
  <div class="modal fade" id="addBusModal" tabindex="-1">
    <div class="modal-dialog">
      <form action="/admin/buses" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add New Bus</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-2">
            <label class="form-label">Bus Number</label>
            <input type="text" name="bus_number" class="form-control" placeholder="e.g. BUS-01" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Route</label>
            <input type="text" name="route_name" class="form-control" placeholder="e.g. City Center - Campus" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Capacity</label>
            <input type="number" name="capacity" class="form-control" placeholder="e.g. 40" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Driver</label>
            <select name="driver_id" class="form-select">
              <option value="">-- Unassigned --</option>
              <% drivers.forEach(d => { %>
                <option value="<%= d.id %>"><%= d.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">Add Bus</button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
