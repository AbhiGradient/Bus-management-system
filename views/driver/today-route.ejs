<%- include('../partials/header', {
  pageTitle: "Today's Route",
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'today-route'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: "Today's Route"
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-signpost-split-fill text-primary"></i>
        Today's Route
      </h3>

      <% if (!bus) { %>

        <div class="card p-4 text-center text-muted">
          No bus has been assigned to you yet. Please contact the administration.
        </div>

      <% } else { %>

        <div class="card p-3 mb-3 d-flex flex-row justify-content-between align-items-center flex-wrap gap-2">
          <div>
            <h5 class="mb-0"><%= bus.bus_number %> — <%= bus.route_name %></h5>
          </div>
          <span class="badge <%= bus.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
            <%= bus.status === 'active' ? 'Trip In Progress' : 'Not Started' %>
          </span>
        </div>

        <div class="card p-3 mb-3">
          <h5 class="mb-3">Passenger List</h5>
          <% if (students.length === 0) { %>
            <p class="text-muted mb-0">No students are assigned to this route yet.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr><th>#</th><th>Name</th><th>Roll No</th><th>Department</th></tr>
                </thead>
                <tbody>
                  <% students.forEach((s, i) => { %>
                    <tr>
                      <td><%= i + 1 %></td>
                      <td><%= s.name %></td>
                      <td><%= s.roll_no %></td>
                      <td><%= s.department %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <div class="d-flex gap-2">
          <a href="/driver/trip-start" class="btn btn-success">
            <i class="bi bi-play-fill"></i>
            Start Trip
          </a>
          <a href="/driver/trip-end" class="btn btn-outline-danger">
            <i class="bi bi-stop-fill"></i>
            End Trip
          </a>
        </div>

      <% } %>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
