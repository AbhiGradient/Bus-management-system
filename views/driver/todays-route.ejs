<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Today's Route | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/driver/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Driver</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/driver/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link active" href="/driver/today-route"><i class="bi bi-signpost-split"></i> Today's Route</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/trip-start"><i class="bi bi-play-circle"></i> Start Trip</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/trip-end"><i class="bi bi-stop-circle"></i> End Trip</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/attendence"><i class="bi bi-clipboard-check"></i> Attendance</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/live-location"><i class="bi bi-geo-alt"></i> Live Location</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/notifications"><i class="bi bi-bell"></i> Notifications</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/driver-profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <h3 class="mb-0"><i class="bi bi-signpost-split"></i> Today's Route</h3>
        <% if (trip) { %>
          <span class="badge badge-status
            <%= trip.status === 'completed' ? 'bg-success' : trip.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
            <%= trip.status === 'not_started' ? 'Not Started' : trip.status === 'ongoing' ? 'Trip Ongoing' : 'Trip Completed' %>
          </span>
        <% } %>
      </div>
      <p class="text-muted">Route and pickup details for <%= new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>.</p>

      <% if (!bus) { %>
        <div class="card p-4 mt-3">
          <p class="text-muted mb-0">No bus has been assigned to you yet. Please contact the administrator.</p>
        </div>
      <% } else { %>
        <div class="row g-3 mt-1">
          <div class="col-md-4">
            <div class="stat-card bg-c1">
              <i class="bi bi-bus-front-fill fs-3"></i>
              <h2><%= bus.bus_number %></h2>
              <div>Bus Number</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card bg-c2">
              <i class="bi bi-signpost-split-fill fs-3"></i>
              <h5 class="mb-0"><%= bus.route_name %></h5>
              <div>Route</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card bg-c5">
              <i class="bi bi-people-fill fs-3"></i>
              <h2><%= students.length %> / <%= bus.capacity %></h2>
              <div>Students on Route</div>
            </div>
          </div>
        </div>

        <div class="card p-3 mt-4">
          <h5 class="mb-3"><i class="bi bi-geo-alt-fill"></i> Pickup Points</h5>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Student</th>
                  <th>Roll No</th>
                  <th>Department</th>
                  <th>Pickup Address</th>
                  <th>Phone</th>
                </tr>
              </thead>
              <tbody>
                <% if (students.length === 0) { %>
                  <tr><td colspan="6" class="text-center text-muted py-3">No students assigned to this route yet.</td></tr>
                <% } %>
                <% students.forEach((s, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><%= s.name %></td>
                    <td><%= s.roll_no %></td>
                    <td><%= s.department || '—' %></td>
                    <td><%= s.address || '—' %></td>
                    <td><%= s.phone || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="d-flex gap-2 mt-3">
          <a href="/driver/trip-start" class="btn btn-primary"><i class="bi bi-play-circle"></i> Go to Start Trip</a>
          <a href="/driver/attendence" class="btn btn-secondary"><i class="bi bi-clipboard-check"></i> Mark Attendance</a>
        </div>
      <% } %>

    </div>
  </div>

   <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
