<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Driver Dashboard | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/driver/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Driver</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link active" href="/driver/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/driver/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <h3 class="mb-1">Welcome, <%= user.name %> 👋</h3>
      <p class="text-muted">Here are your assigned bus details for today.</p>

      <% if (!bus) { %>
        <div class="card p-4 mt-3">
          <p class="text-muted mb-0">No bus has been assigned to you yet. Please contact the administrator.</p>
        </div>
      <% } else { %>
        <div class="row g-3 mt-1">
          <div class="col-md-4">
            <div class="stat-card bg-c1">
              <i class="bi bi-bus-front-fill fs-3"></i>
              <h2><%= bus.bus_number %></h2>
              <div>Bus Number</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card bg-c2">
              <i class="bi bi-signpost-split-fill fs-3"></i>
              <h5 class="mb-0"><%= bus.route_name %></h5>
              <div>Route</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card bg-c5">
              <i class="bi bi-people-fill fs-3"></i>
              <h2><%= students.length %> / <%= bus.capacity %></h2>
              <div>Students Assigned</div>
            </div>
          </div>
        </div>

        <div class="card p-3 mt-4">
          <h5 class="mb-3"><i class="bi bi-people-fill"></i> Student List</h5>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Roll No</th>
                  <th>Department</th>
                  <th>Phone</th>
                </tr>
              </thead>
              <tbody>
                <% if (students.length === 0) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3">No students assigned to this bus yet.</td></tr>
                <% } %>
                <% students.forEach((s, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><%= s.name %></td>
                    <td><%= s.roll_no %></td>
                    <td><%= s.department || '—' %></td>
                    <td><%= s.phone || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

       
    </div>
  </div>
   <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
