<%- include('../partials/header', {
  pageTitle: 'Driver Dashboard',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'dashboard'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Driver Dashboard'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-1">Welcome, <%= driver.name %> 👋</h3>
      <p class="text-muted">Phone: <strong><%= driver.phone || '—' %></strong></p>

      <div class="row g-3 mt-2">

        <div class="col-md-6">
          <div class="card p-4 h-100">
            <h5><i class="bi bi-bus-front-fill text-primary"></i> My Bus</h5>
            <hr>
            <% if (bus) { %>
              <p class="mb-1"><strong>Bus Number:</strong> <%= bus.bus_number %></p>
              <p class="mb-1"><strong>Route:</strong> <%= bus.route_name %></p>
              <p class="mb-1"><strong>Capacity:</strong> <%= bus.capacity %></p>
              <p class="mb-0">
                <strong>Trip Status:</strong>
                <span class="badge <%= bus.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                  <%= bus.status === 'active' ? 'On Trip' : 'Not Started' %>
                </span>
              </p>
            <% } else { %>
              <p class="text-muted mt-3">No bus has been assigned to you yet. Please contact the administration.</p>
            <% } %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card p-4 h-100">
            <h5><i class="bi bi-people-fill text-warning"></i> Students Onboard</h5>
            <hr>
            <p class="fs-3 fw-bold mb-1"><%= students.length %></p>
            <p class="text-muted mb-3">Students assigned to your bus</p>
            <a href="/driver/today-route" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-signpost-split"></i>
              View Today's Route
            </a>
          </div>
        </div>

      </div>

      <div class="card p-4 mt-3">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-people text-secondary"></i> Student Roster</h5>
          <a href="/driver/qr-scanner" class="btn btn-sm btn-primary">
            <i class="bi bi-clipboard-check"></i>
            Take Attendance
          </a>
        </div>
        <hr>

        <% if (students.length === 0) { %>
          <p class="text-muted mb-0">No students are assigned to your bus yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr><th>#</th><th>Name</th><th>Roll No</th><th>Department</th><th>Year</th><th>Phone</th></tr>
              </thead>
              <tbody>
                <% students.forEach((s, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><%= s.name %></td>
                    <td><%= s.roll_no %></td>
                    <td><%= s.department %></td>
                    <td><%= s.year %></td>
                    <td><%= s.phone || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
