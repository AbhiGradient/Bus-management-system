<%- include('../partials/header', {
  pageTitle: 'Start Trip',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'trip-start'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Start Trip'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-play-circle-fill text-success"></i>
        Start Trip
      </h3>

      <% if (!bus) { %>

        <div class="card p-4 text-center text-muted">
          No bus has been assigned to you yet. Please contact the administration.
        </div>

      <% } else { %>

        <div class="card p-4" style="max-width: 480px;">

          <p class="mb-2"><strong>Bus:</strong> <%= bus.bus_number %></p>
          <p class="mb-3"><strong>Route:</strong> <%= bus.route_name %></p>

          <% if (bus.status === 'active') { %>

            <div class="alert alert-success mb-3">
              <i class="bi bi-check-circle"></i>
              This trip is already in progress.
            </div>

          <% } else { %>

            <p class="text-muted mb-3">
              Starting the trip marks your bus as active so students and admins
              can see you're on the road.
            </p>

            <form action="/driver/trip-start" method="POST">
              <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-play-fill"></i>
                Confirm & Start Trip
              </button>
            </form>

          <% } %>

        </div>

      <% } %>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
