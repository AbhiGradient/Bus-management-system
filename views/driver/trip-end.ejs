<%- include('../partials/header', {
  pageTitle: 'End Trip',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'trip-end'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'End Trip'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-stop-circle-fill text-danger"></i>
        End Trip
      </h3>

      <% if (!bus) { %>

        <div class="card p-4 text-center text-muted">
          No bus has been assigned to you yet. Please contact the administration.
        </div>

      <% } else { %>

        <div class="card p-4" style="max-width: 480px;">

          <p class="mb-2"><strong>Bus:</strong> <%= bus.bus_number %></p>
          <p class="mb-3"><strong>Route:</strong> <%= bus.route_name %></p>

          <% if (bus.status !== 'active') { %>

            <div class="alert alert-secondary mb-3">
              <i class="bi bi-info-circle"></i>
              There's no trip currently in progress.
            </div>

          <% } else { %>

            <p class="text-muted mb-3">
              Ending the trip marks your bus as inactive until the next trip starts.
            </p>

            <form action="/driver/trip-end" method="POST">
              <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-stop-fill"></i>
                Confirm & End Trip
              </button>
            </form>

          <% } %>

        </div>

      <% } %>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
