<%- include('../partials/header', {
  pageTitle: 'Driver Profile',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'profile'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Driver Profile'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-person-circle text-primary"></i>
        My Profile
      </h3>

      <% if (typeof message !== 'undefined' && message) { %>

        <div class="alert alert-success">
          <i class="bi bi-check-circle-fill"></i>
          <%= message %>
        </div>

      <% } %>

      <div class="row g-4">

        <!-- Driver Information -->

        <div class="col-lg-4">

          <div class="card h-100">

            <div class="card-body text-center">

              <i class="bi bi-person-circle display-1 text-primary"></i>

              <h4 class="mt-3">
                <%= driver.name %>
              </h4>

              <p class="text-muted mb-1">
                Driver
              </p>

              <hr>

              <div class="text-start">

                <p>
                  <strong>Email</strong><br>
                  <%= driver.email %>
                </p>

                <p>
                  <strong>Phone</strong><br>
                  <%= driver.phone || '—' %>
                </p>

              </div>

            </div>

          </div>

        </div>

        <!-- Edit Profile -->

        <div class="col-lg-8">

          <div class="card">

            <div class="card-header">

              <h5 class="mb-0">
                Edit Profile
              </h5>

            </div>

            <div class="card-body">

              <form action="/driver/profile?_method=PUT" method="POST">

                <div class="mb-3">

                  <label class="form-label">
                    Full Name
                  </label>

                  <input
                    type="text"
                    class="form-control"
                    name="name"
                    value="<%= driver.name %>"
                    required>

                </div>

                <div class="mb-3">

                  <label class="form-label">
                    Email
                  </label>

                  <input
                    type="email"
                    class="form-control"
                    value="<%= driver.email %>"
                    readonly>

                </div>

                <div class="mb-3">

                  <label class="form-label">
                    Phone Number
                  </label>

                  <input
                    type="text"
                    class="form-control"
                    name="phone"
                    value="<%= driver.phone || '' %>">

                </div>

                <div class="mb-4">

                  <label class="form-label">
                    New Password
                  </label>

                  <input
                    type="password"
                    class="form-control"
                    name="password"
                    placeholder="Leave blank if you don't want to change it">

                </div>

                <button class="btn btn-primary">

                  <i class="bi bi-check-circle"></i>

                  Save Changes

                </button>

              </form>

            </div>

          </div>

        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>