<!--
  qr-generator.ejs  (Admin)
  ------------------------------------------------------------
  Expected route: GET /admin/qr-generator  ->  routes/qr.js
  Expected locals:
    user     -> req.session.user               (already global via res.locals)
    students -> [{ id, name, roll_no, department, bus_number }]
                same shape as the join used in routes/admin.js "students" query

  QR payload: each pass encodes a small JSON string so the scanner
  (qr-scanner.ejs) can identify the student without a DB round trip:
    { "type": "student", "id": <student.id>, "roll_no": "<roll_no>" }

  Uses the "qrcode" package's browser build via CDN (no server-side
  dependency needed) to draw the code onto a <canvas>.
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QR Generator | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/qr-generator"><i class="bi bi-qr-code"></i> QR Generator</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/attendance-report"><i class="bi bi-clipboard-data"></i> Attendance Report</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h3 class="mb-0"><i class="bi bi-qr-code"></i> QR Code Generator</h3>
        <div class="d-flex gap-2">
          <input type="text" id="studentSearch" class="form-control form-control-sm" style="width: 220px;" placeholder="Search name or roll no...">
          <button class="btn btn-outline-secondary btn-sm" id="printAllBtn">
            <i class="bi bi-printer"></i> Print All Passes
          </button>
        </div>
      </div>
      <p class="text-muted">Select a student to generate a scannable boarding pass for bus attendance.</p>

      <div class="row g-3">
        <!-- Student list -->
        <div class="col-lg-7">
          <div class="card p-3">
            <div class="table-responsive">
              <table class="table table-hover align-middle" id="studentTable">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Roll No</th>
                    <th>Department</th>
                    <th>Bus</th>
                    <th class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!students || students.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-3">No students found.</td></tr>
                  <% } %>
                  <% students.forEach((s, i) => { %>
                    <tr
                      class="qr-row"
                      data-id="<%= s.id %>"
                      data-name="<%= s.name %>"
                      data-roll="<%= s.roll_no %>"
                      data-department="<%= s.department || '—' %>"
                      data-bus="<%= s.bus_number || 'Unassigned' %>"
                      data-search="<%= (s.name + ' ' + s.roll_no).toLowerCase() %>"
                    >
                      <td><%= i + 1 %></td>
                      <td><%= s.name %></td>
                      <td><%= s.roll_no %></td>
                      <td><%= s.department || '—' %></td>
                      <td><%= s.bus_number || '—' %></td>
                      <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-primary generate-btn">
                          <i class="bi bi-qr-code"></i> Generate
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- QR preview / boarding pass -->
        <div class="col-lg-5">
          <div class="card p-3" style="position: sticky; top: 90px;">
            <h5 class="mb-3"><i class="bi bi-card-heading"></i> Boarding Pass Preview</h5>

            <div class="qr-pass" id="qrPass">
              <div class="qr-pass-name" id="passName">No student selected</div>
              <div class="qr-pass-meta" id="passMeta">Select a student from the list</div>

              <div class="qr-pass-canvas-wrap" id="qrCanvasWrap">
                <span class="qr-pass-placeholder"><i class="bi bi-qr-code fs-2 d-block mb-1"></i>QR appears here</span>
              </div>

              <div class="qr-pass-badge" id="passBusBadge">—</div>
            </div>

            <div class="d-grid gap-2 mt-3">
              <button type="button" class="btn btn-success" id="downloadBtn" disabled>
                <i class="bi bi-download"></i> Download PNG
              </button>
              <button type="button" class="btn btn-outline-secondary" id="printOneBtn" disabled>
                <i class="bi bi-printer"></i> Print This Pass
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Hidden container used only when printing every pass at once -->
      <div id="printAllContainer" style="display: none;"></div>

    </div>
  </div>

  <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
  <script src="/js/script.js"></script>

  <script>
    let currentStudent = null;

    function qrPayload(row) {
      return JSON.stringify({
        type: 'student',
        id: row.dataset.id,
        roll_no: row.dataset.roll
      });
    }

    function renderPass(row) {
      currentStudent = row;

      document.getElementById('passName').textContent = row.dataset.name;
      document.getElementById('passMeta').textContent =
        row.dataset.roll + ' · ' + row.dataset.department;
      document.getElementById('passBusBadge').textContent = row.dataset.bus;

      const wrap = document.getElementById('qrCanvasWrap');
      wrap.innerHTML = '';
      const canvas = document.createElement('canvas');
      wrap.appendChild(canvas);

      QRCode.toCanvas(canvas, qrPayload(row), { width: 200, margin: 1 }, function (err) {
        if (err) {
          wrap.innerHTML = '<span class="qr-pass-placeholder text-danger">Failed to generate QR</span>';
          return;
        }
        document.getElementById('downloadBtn').disabled = false;
        document.getElementById('printOneBtn').disabled = false;
      });
    }

    document.querySelectorAll('.generate-btn').forEach(btn => {
      btn.addEventListener('click', () => renderPass(btn.closest('tr')));
    });

    // Row click also generates (not just the button)
    document.querySelectorAll('.qr-row').forEach(row => {
      row.addEventListener('click', (e) => {
        if (e.target.closest('.generate-btn')) return; // avoid double-trigger
        renderPass(row);
      });
      row.style.cursor = 'pointer';
    });

    // Live search filter
    document.getElementById('studentSearch').addEventListener('input', function () {
      const q = this.value.trim().toLowerCase();
      document.querySelectorAll('#studentTable tbody tr.qr-row').forEach(row => {
        row.style.display = row.dataset.search.includes(q) ? '' : 'none';
      });
    });

    // Download the currently previewed pass as a PNG
    document.getElementById('downloadBtn').addEventListener('click', () => {
      if (!currentStudent) return;
      const canvas = document.querySelector('#qrCanvasWrap canvas');
      if (!canvas) return;
      const link = document.createElement('a');
      link.download = 'qr-pass-' + currentStudent.dataset.roll + '.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    });

    // Print just the currently previewed pass
    document.getElementById('printOneBtn').addEventListener('click', () => {
      window.print();
    });

    // Print every student's pass at once (builds a temporary printable grid)
    document.getElementById('printAllBtn').addEventListener('click', async () => {
      const container = document.getElementById('printAllContainer');
      container.innerHTML = '';

      const rows = document.querySelectorAll('#studentTable tbody tr.qr-row');
      for (const row of rows) {
        const passDiv = document.createElement('div');
        passDiv.className = 'qr-pass';
        passDiv.style.display = 'inline-block';
        passDiv.style.margin = '10px';
        passDiv.style.width = '260px';

        const canvas = document.createElement('canvas');
        await new Promise(resolve => {
          QRCode.toCanvas(canvas, qrPayload(row), { width: 160, margin: 1 }, () => resolve());
        });

        passDiv.innerHTML =
          '<div class="qr-pass-name">' + row.dataset.name + '</div>' +
          '<div class="qr-pass-meta">' + row.dataset.roll + ' · ' + row.dataset.department + '</div>' +
          '<div class="qr-pass-canvas-wrap"></div>' +
          '<div class="qr-pass-badge">' + row.dataset.bus + '</div>';
        passDiv.querySelector('.qr-pass-canvas-wrap').appendChild(canvas);
        container.appendChild(passDiv);
      }

      container.style.display = 'block';
      document.getElementById('qrPass').closest('.card').style.display = 'none';
      document.querySelector('.col-lg-7').style.display = 'none';

      window.print();

      // Restore the normal view after the print dialog closes
      container.style.display = 'none';
      document.getElementById('qrPass').closest('.card').style.display = '';
      document.querySelector('.col-lg-7').style.display = '';
    });
  </script>
</body>
</html>
