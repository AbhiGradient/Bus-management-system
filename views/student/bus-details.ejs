<%- include('../partials/header', {
  pageTitle: 'Bus Details',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'bus-details'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Bus Details'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-bus-front-fill text-primary"></i>
        My Bus Details
      </h3>

      <% if (!bus) { %>

        <div class="card p-4 text-center text-muted">
          No bus has been assigned to you yet. Please contact the administration.
        </div>

      <% } else { %>

        <div class="row g-3">

          <div class="col-md-6">
            <div class="card p-4 h-100">
              <h5 class="mb-3"><i class="bi bi-truck-front"></i> Vehicle Info</h5>
              <hr>
              <p class="mb-2"><strong>Bus Number:</strong> <%= bus.bus_number %></p>
              <p class="mb-2"><strong>Route:</strong> <%= bus.route_name %></p>
              <p class="mb-2"><strong>Capacity:</strong> <%= bus.capacity %> seats</p>
              <p class="mb-0">
                <strong>Status:</strong>
                <span class="badge <%= bus.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                  <%= bus.status %>
                </span>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card p-4 h-100">
              <h5 class="mb-3"><i class="bi bi-person-badge"></i> Driver Info</h5>
              <hr>
              <p class="mb-2"><strong>Name:</strong> <%= bus.driver_name || 'Not assigned yet' %></p>
              <p class="mb-2"><strong>Contact:</strong> <%= bus.driver_phone || '—' %></p>
              <p class="mb-0"><strong>My Seat:</strong> <%= mySeatNo ? ('#' + mySeatNo) : 'Not allocated yet' %></p>
            </div>
          </div>

        </div>

        <div class="card p-4 mt-3">
          <h5 class="mb-2"><i class="bi bi-signpost-split"></i> Route</h5>
          <hr>
          <p class="text-muted mb-0"><%= bus.route_name %></p>
          <a href="/student/route-map" class="btn btn-sm btn-outline-primary mt-3">
            <i class="bi bi-map"></i>
            View Route Map
          </a>
        </div>

      <% } %>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
