<%- include('../partials/header', {
  pageTitle: 'Payment History',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'payment-history'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Payment History'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-credit-card-2-front-fill text-primary"></i>
        Payment History
      </h3>

      <div class="card p-3">

        <div class="table-responsive">

          <table class="table table-hover align-middle">

            <thead>
              <tr>
                <th>#</th>
                <th>Receipt No.</th>
                <th>Amount</th>
                <th>Payment Date</th>
                <th>Method</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>

            <tbody>

              <% if (!payments || payments.length === 0) { %>

                <tr>
                  <td colspan="7" class="text-center text-muted py-4">
                    No payment records found.
                  </td>
                </tr>

              <% } %>

              <% payments.forEach((payment, index) => { %>

                <tr>

                  <td>
                    <%= index + 1 %>
                  </td>

                  <td style="font-family: monospace;">
                    <%= payment.receipt_no %>
                  </td>

                  <td>
                    ₹<%= Number(payment.amount).toLocaleString('en-IN') %>
                  </td>

                  <td>
                    <%= payment.transaction_date
                      ? new Date(payment.transaction_date).toLocaleDateString('en-IN')
                      : '—'
                    %>
                  </td>

                  <td>
                    <%= payment.payment_method || 'UPI' %>
                  </td>

                  <td>

                    <% if (payment.status === 'success') { %>

                      <span class="badge bg-success">
                        Success
                      </span>

                    <% } else { %>

                      <span class="badge bg-warning text-dark">
                        <%= payment.status %>
                      </span>

                    <% } %>

                  </td>

                  <td class="text-center">

                    <a href="/payment/receipt/<%= payment.receipt_no %>"
                       class="btn btn-outline-primary btn-sm me-1">

                      <i class="bi bi-receipt"></i>
                      Receipt

                    </a>

                    <a href="/payment/receipt/<%= payment.receipt_no %>/download"
                       class="btn btn-success btn-sm">

                      <i class="bi bi-download"></i>
                      PDF

                    </a>

                  </td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>