<%- include('../partials/header', {
  pageTitle: 'Payment History',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'payment-history'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Payment History'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-credit-card-2-front-fill text-primary"></i>
        Payment History
      </h3>

      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr><th>#</th><th>Amount</th><th>Paid Date</th><th>Due Date</th><th>Status</th></tr>
            </thead>
            <tbody>

              <% const paidFees = fees.filter(f => f.status === 'paid'); %>

              <% if (paidFees.length === 0) { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-3">
                    No payments recorded yet.
                  </td>
                </tr>
              <% } %>

              <% paidFees.forEach((f, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td>₹<%= Number(f.amount).toLocaleString('en-IN') %></td>
                  <td><%= f.paid_date ? new Date(f.paid_date).toLocaleDateString('en-IN') : '—' %></td>
                  <td><%= f.due_date ? new Date(f.due_date).toLocaleDateString('en-IN') : '—' %></td>
                  <td><span class="badge bg-success">paid</span></td>
                </tr>
              <% }) %>

            </tbody>
          </table>
        </div>
      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
