<%- include('../partials/header', {
  pageTitle: 'Request Bus Change',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'request-bus-change'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Request Bus Change'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-signpost-2-fill text-primary"></i>
        Request a Bus Change
      </h3>

      <div class="row g-3">

        <div class="col-md-5">
          <div class="card p-3">
            <h5 class="mb-3">Current Assignment</h5>
            <hr>
            <% if (bus) { %>
              <p class="mb-2"><strong>Bus Number:</strong> <%= bus.bus_number %></p>
              <p class="mb-0"><strong>Route:</strong> <%= bus.route_name %></p>
            <% } else { %>
              <p class="text-muted mb-0">You don't have a bus assigned yet.</p>
            <% } %>
          </div>
        </div>

        <div class="col-md-7">
          <div class="card p-3">
            <h5 class="mb-3">New Request</h5>

            <form action="/student/request-bus-change" method="POST">

              <div class="mb-2">
                <label class="form-label">Preferred Bus</label>
                <select name="requested_bus_id" class="form-select" required>
                  <option value="">-- Select a bus --</option>
                  <% buses.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.bus_number %> — <%= b.route_name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Reason</label>
                <textarea
                  name="message"
                  rows="4"
                  class="form-control"
                  placeholder="Tell us why you'd like to change your bus..."
                  required></textarea>
              </div>

              <button type="submit" class="btn btn-primary">
                <i class="bi bi-send"></i>
                Submit Request
              </button>

            </form>
          </div>
        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
