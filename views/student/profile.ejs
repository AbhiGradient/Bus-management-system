<%- include('../partials/header', {
  pageTitle: 'My Profile',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'profile'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'My Profile'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-person-circle text-primary"></i>
        My Profile
      </h3>

      <div class="row g-3">

        <div class="col-md-6">
          <div class="card p-3 h-100">
            <h5 class="mb-3">Academic Info</h5>
            <hr>
            <p class="mb-2"><strong>Roll No:</strong> <%= student.roll_no %></p>
            <p class="mb-2"><strong>Department:</strong> <%= student.department || '—' %></p>
            <p class="mb-0"><strong>Year:</strong> <%= student.year || '—' %></p>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card p-3 h-100">
            <h5 class="mb-3">Contact Details</h5>

            <form action="/student/profile" method="POST">

              <div class="mb-2">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
              </div>

              <div class="mb-2">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" value="<%= user.email %>" required>
              </div>

              <div class="mb-2">
                <label class="form-label">Phone</label>
                <input type="text" name="phone" class="form-control" value="<%= user.phone || '' %>">
              </div>

              <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea name="address" rows="2" class="form-control"><%= student.address || '' %></textarea>
              </div>

              <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle"></i>
                Save Changes
              </button>

            </form>
          </div>
        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
