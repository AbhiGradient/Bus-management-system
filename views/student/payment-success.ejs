```ejs
<%- include('../partials/header', {
  pageTitle: 'Payment Successful',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'fee-status'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Payment Successful'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <div class="container py-4">

        <div class="card shadow border-0">

          <div class="card-body text-center p-5">

            <div class="mb-4">
              <i class="bi bi-check-circle-fill text-success"
                 style="font-size:90px;"></i>
            </div>

            <h2 class="fw-bold text-success">
              Payment Successful
            </h2>

            <p class="text-muted mb-4">
              Your bus fee payment has been received successfully.
            </p>

            <% if (payment) { %>

              <div class="table-responsive">

                <table class="table table-bordered align-middle w-auto mx-auto">

                  <tbody>

                    <tr>
                      <th>Receipt No.</th>
                      <td>
                        <%= payment.receipt_no %>
                      </td>
                    </tr>

                    <tr>
                      <th>Amount Paid</th>
                      <td>
                        ₹<%= Number(payment.amount).toLocaleString('en-IN') %>
                      </td>
                    </tr>

                    <tr>
                      <th>Payment Status</th>
                      <td>
                        <span class="badge bg-success fs-6">
                          Success
                        </span>
                      </td>
                    </tr>

                    <% if(payment.razorpay_payment_id){ %>

                    <tr>
                      <th>Transaction ID</th>
                      <td>
                        <%= payment.razorpay_payment_id %>
                      </td>
                    </tr>

                    <% } %>

                    <% if(payment.created_at){ %>

                    <tr>
                      <th>Payment Date</th>
                      <td>
                        <%= new Date(payment.created_at).toLocaleString('en-IN') %>
                      </td>
                    </tr>

                    <% } %>

                  </tbody>

                </table>

              </div>

              <div class="mt-4">

                <a href="/payment/receipt/<%= payment.receipt_no %>"
                   class="btn btn-primary">

                  <i class="bi bi-receipt me-1"></i>
                  View Receipt

                </a>

              </div>

            <% } else { %>

              <div class="alert alert-warning mt-3">
                Payment details could not be loaded.
              </div>

            <% } %>

            <hr class="my-4">

            <div class="d-flex justify-content-center gap-3 flex-wrap">

              <a href="/student/payment-history"
                 class="btn btn-outline-primary">

                <i class="bi bi-clock-history me-1"></i>
                Payment History

              </a>

              <a href="/student/fees-status"
                 class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left me-1"></i>
                Back to Fee Status

              </a>

            </div>

          </div>

        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>

