<%- include('partials/header', {
  pageTitle: 'Payment Successful',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('partials/sidebar', {
    currentPage: 'fee-status'
  }) %>

  <%- include('partials/navbar', {
    pageLabel: 'Payment Successful'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <div class="row justify-content-center">
        <div class="col-lg-7">

          <div class="card p-5 text-center success-card">

            <div class="success-icon-wrap">
              <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" class="success-circle"/>
                <path d="M8 12.5l2.5 2.5L16 9.5" class="success-check"/>
              </svg>
            </div>

            <h2 class="mt-4 mb-2 text-success">
              Payment Successful!
            </h2>

            <p class="text-muted mb-4">
              Your transport fee has been paid successfully.
            </p>

            <div class="p-3 mb-4 rounded border bg-light">

              <table class="table table-borderless mb-0">
                <tbody>

                  <tr>
                    <td class="text-muted" style="width:45%;">
                      Receipt Number
                    </td>
                    <td class="fw-semibold">
                      <%= payment.receipt_number %>
                    </td>
                  </tr>

                  <tr>
                    <td class="text-muted">
                      Transaction ID
                    </td>
                    <td class="fw-semibold">
                      <%= payment.transaction_id %>
                    </td>
                  </tr>

                  <tr>
                    <td class="text-muted">
                      Amount Paid
                    </td>
                    <td class="fw-semibold text-success">
                      ₹<%= Number(payment.amount).toLocaleString('en-IN') %>
                    </td>
                  </tr>

                  <tr>
                    <td class="text-muted">
                      Payment Date
                    </td>
                    <td class="fw-semibold">
                      <%= payment.payment_date ? new Date(payment.payment_date).toLocaleDateString('en-IN') : '—' %>
                    </td>
                  </tr>

                  <tr>
                    <td class="text-muted">
                      Payment Method
                    </td>
                    <td class="fw-semibold">
                      <%= payment.payment_method %>
                    </td>
                  </tr>

                  <tr>
                    <td class="text-muted">
                      Status
                    </td>
                    <td>
                      <span class="badge bg-success">
                        <%= payment.status.toUpperCase() %>
                      </span>
                    </td>
                  </tr>

                </tbody>
              </table>

            </div>

            <p class="text-muted mb-4">
              <i class="bi bi-check-circle-fill text-success"></i>
              Thank you for completing your transport fee payment.
            </p>

            <div class="d-flex justify-content-center gap-2 flex-wrap">

              <a href="/payment/receipt/<%= payment.receipt_number %>"
                 class="btn btn-primary">
                <i class="bi bi-receipt"></i>
                View Receipt
              </a>

              <a href="/payment/receipt/<%= payment.receipt_number %>/download"
                 class="btn btn-secondary">
                <i class="bi bi-download"></i>
                Download PDF
              </a>

              <a href="/student/fees-status"
                 class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Back to Fees
              </a>

            </div>

          </div>

        </div>
      </div>

    </main>

    <%- include('partials/footer') %>

  </div>

</div>

<style>
.success-card{
    animation:fadeIn .5s ease;
}

.success-icon-wrap{
    display:flex;
    justify-content:center;
}

.success-circle{
    stroke:#198754;
    stroke-dasharray:63;
    stroke-dashoffset:63;
    animation:drawCircle .6s forwards;
}

.success-check{
    stroke:#198754;
    stroke-dasharray:20;
    stroke-dashoffset:20;
    animation:drawCheck .4s .5s forwards;
}

@keyframes drawCircle{
    to{
        stroke-dashoffset:0;
    }
}

@keyframes drawCheck{
    to{
        stroke-dashoffset:0;
    }
}

@keyframes fadeIn{
    from{
        opacity:0;
        transform:translateY(20px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>