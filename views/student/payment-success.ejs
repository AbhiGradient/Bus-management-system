<%- include('../partials/header', {
  pageTitle: 'Payment Successful',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'fee-status'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Payment Successful'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <div class="card text-center p-5">

        <div class="mb-4">
          <i class="bi bi-check-circle-fill text-success" style="font-size:80px;"></i>
        </div>

        <h2 class="text-success mb-3">
          Payment Successful
        </h2>

        <p class="text-muted">
          Your transport fee payment has been recorded successfully.
        </p>

        <% if (payment) { %>

          <table class="table table-bordered w-auto mx-auto mt-4">

            <tr>
              <th>Receipt No.</th>
              <td><%= payment.receipt_no %></td>
            </tr>

            <tr>
              <th>Amount</th>
              <td>₹<%= Number(payment.amount).toLocaleString('en-IN') %></td>
            </tr>

            <tr>
              <th>Status</th>
              <td>
                <span class="badge bg-success">Success</span>
              </td>
            </tr>

          </table>

          <div class="mt-4">

            <a href="/payment/receipt/<%= payment.receipt_no %>"
               class="btn btn-primary me-2">

              <i class="bi bi-receipt"></i>
              View Receipt

            </a>

          </div>

        <% } %>

        <div class="mt-3">

          <a href="/student/payment-history"
             class="btn btn-outline-primary me-2">

            Payment History

          </a>

          <a href="/student/fees-status"
             class="btn btn-outline-secondary">

            Back to Fee Status

          </a>

        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>