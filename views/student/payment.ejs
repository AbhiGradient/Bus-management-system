<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Pay Bus Fee | Smart College Bus
    </title>


    <link
        rel="stylesheet"
        href="/css/main.css"
    >


    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    >


    <style>

        /*
        =====================================================
        PAYMENT PAGE
        =====================================================
        */

        .payment-page {

            max-width:
                1100px;

            margin:
                40px auto;

            padding:
                20px;

        }


        /*
        =====================================================
        PAGE HEADER
        =====================================================
        */

        .payment-heading {

            margin-bottom:
                25px;

        }


        .payment-heading h1 {

            color:
                #132f4b;

            margin-bottom:
                8px;

        }


        .payment-heading p {

            color:
                #666;

        }


        /*
        =====================================================
        MAIN GRID
        =====================================================
        */

        .payment-layout {

            display:
                grid;

            grid-template-columns:
                300px 1fr;

            gap:
                25px;

            align-items:
                start;

        }


        /*
        =====================================================
        STUDENT / FEE SUMMARY
        =====================================================
        */

        .fee-summary {

            background:
                #fff;

            border-radius:
                14px;

            padding:
                25px;

            box-shadow:
                0 6px 20px
                rgba(
                    0,
                    0,
                    0,
                    0.10
                );

            position:
                sticky;

            top:
                90px;

        }


        .fee-summary h2 {

            color:
                #132f4b;

            font-size:
                20px;

            margin-bottom:
                20px;

        }


        .student-info {

            border-bottom:
                1px solid #eee;

            padding-bottom:
                15px;

            margin-bottom:
                15px;

        }


        .student-info p {

            margin:
                7px 0;

            font-size:
                14px;

        }


        .student-info strong {

            color:
                #132f4b;

        }


        .fee-amount-box {

            background:
                #f5f7fa;

            border-radius:
                10px;

            padding:
                20px;

            text-align:
                center;

            margin-top:
                20px;

        }


        .fee-amount-box span {

            display:
                block;

            color:
                #666;

            font-size:
                14px;

            margin-bottom:
                8px;

        }


        .fee-amount {

            font-size:
                30px;

            font-weight:
                700;

            color:
                #e10600;

        }


        /*
        =====================================================
        PAYMENT METHODS
        =====================================================
        */

        .payment-container {

            background:
                #fff;

            border-radius:
                14px;

            box-shadow:
                0 6px 20px
                rgba(
                    0,
                    0,
                    0,
                    0.10
                );

            overflow:
                hidden;

        }


        .payment-methods {

            display:
                grid;

            grid-template-columns:
                repeat(
                    5,
                    1fr
                );

            border-bottom:
                1px solid #eee;

        }


        .method-button {

            border:
                none;

            background:
                #fff;

            padding:
                15px 8px;

            cursor:
                pointer;

            color:
                #555;

            font-weight:
                600;

            font-size:
                12px;

            transition:
                0.2s;

        }


        .method-button i {

            display:
                block;

            font-size:
                20px;

            margin-bottom:
                7px;

        }


        .method-button:hover {

            background:
                #f5f7fa;

        }


        .method-button.active {

            background:
                #132f4b;

            color:
                #fff;

        }


        /*
        =====================================================
        PAYMENT CONTENT
        =====================================================
        */

        .payment-content {

            padding:
                30px;

        }


        .payment-box {

            display:
                none;

        }


        .payment-box.active {

            display:
                block;

        }


        .payment-box h2 {

            color:
                #132f4b;

            margin-bottom:
                8px;

        }


        .payment-box-description {

            color:
                #666;

            font-size:
                14px;

            margin-bottom:
                20px;

        }


        /*
        =====================================================
        FORM ELEMENTS
        =====================================================
        */

        .form-group {

            margin-bottom:
                15px;

        }


        .form-group label {

            display:
                block;

            margin-bottom:
                6px;

            font-size:
                13px;

            font-weight:
                600;

            color:
                #333;

        }


        .form-group input,
        .form-group select {

            width:
                100%;

            padding:
                12px;

            border:
                1px solid #ccc;

            border-radius:
                7px;

            font-size:
                14px;

            outline:
                none;

        }


        .form-group input:focus,
        .form-group select:focus {

            border-color:
                #132f4b;

            box-shadow:
                0 0 0 3px
                rgba(
                    19,
                    47,
                    75,
                    0.10
                );

        }


        /*
        =====================================================
        CARD ROW
        =====================================================
        */

        .form-row {

            display:
                grid;

            grid-template-columns:
                1fr 1fr;

            gap:
                12px;

        }


        /*
        =====================================================
        CARD LOGOS
        =====================================================
        */

        .card-logos {

            display:
                flex;

            gap:
                10px;

            margin-bottom:
                20px;

            flex-wrap:
                wrap;

        }


        .card-logo {

            padding:
                7px 12px;

            border:
                1px solid #ddd;

            border-radius:
                5px;

            font-size:
                12px;

            font-weight:
                700;

            color:
                #333;

        }


        /*
        =====================================================
        UPI SECTION
        =====================================================
        */

        .upi-layout {

            display:
                grid;

            grid-template-columns:
                1fr 220px;

            gap:
                25px;

            align-items:
                center;

        }


        .upi-id-box {

            background:
                #f5f7fa;

            padding:
                15px;

            border-radius:
                8px;

            margin-bottom:
                20px;

        }


        .upi-id-box strong {

            color:
                #132f4b;

        }


        .qr-box {

            text-align:
                center;

            padding:
                15px;

            border:
                1px solid #ddd;

            border-radius:
                10px;

            background:
                #fff;

        }


        .qr-box img {

            width:
                170px;

            height:
                170px;

            object-fit:
                contain;

        }


        .qr-box p {

            margin-top:
                8px;

            font-size:
                12px;

            color:
                #666;

        }


        /*
        =====================================================
        INFO BOX
        =====================================================
        */

        .info-box {

            background:
                #eef6ff;

            border-left:
                4px solid #132f4b;

            padding:
                14px;

            border-radius:
                6px;

            color:
                #1e4b73;

            font-size:
                13px;

            margin-bottom:
                20px;

        }


        /*
        =====================================================
        SIMULATED PAYMENT NOTICE
        =====================================================
        */

        .simulation-notice {

            background:
                #fff8e1;

            border-left:
                4px solid #f59e0b;

            color:
                #92400e;

            padding:
                12px;

            border-radius:
                6px;

            font-size:
                13px;

            margin-bottom:
                20px;

        }


        /*
        =====================================================
        PAY BUTTON
        =====================================================
        */

        .pay-button {

            width:
                100%;

            border:
                none;

            background:
                #132f4b;

            color:
                #fff;

            padding:
                14px;

            border-radius:
                7px;

            font-size:
                16px;

            font-weight:
                700;

            cursor:
                pointer;

            margin-top:
                10px;

        }


        .pay-button:hover {

            background:
                #0e2439;

        }


        .pay-button:disabled {

            background:
                #999;

            cursor:
                not-allowed;

        }


        /*
        =====================================================
        PROCESSING MESSAGE
        =====================================================
        */

        .processing-message {

            display:
                none;

            text-align:
                center;

            margin-top:
                15px;

            color:
                #132f4b;

            font-size:
                14px;

        }


        .processing-message.show {

            display:
                block;

        }


        /*
        =====================================================
        ERROR MESSAGE
        =====================================================
        */

        .error-message {

            display:
                none;

            background:
                #fee2e2;

            color:
                #991b1b;

            padding:
                12px;

            border-radius:
                7px;

            margin-bottom:
                15px;

            font-size:
                14px;

        }


        .error-message.show {

            display:
                block;

        }


        /*
        =====================================================
        MOBILE
        =====================================================
        */

        @media (
            max-width: 850px
        ) {

            .payment-layout {

                grid-template-columns:
                    1fr;

            }


            .fee-summary {

                position:
                    static;

            }


            .payment-methods {

                grid-template-columns:
                    repeat(
                        3,
                        1fr
                    );

            }


            .upi-layout {

                grid-template-columns:
                    1fr;

            }


            .qr-box {

                max-width:
                    240px;

                margin:
                    auto;

            }

        }


        @media (
            max-width: 500px
        ) {

            .payment-methods {

                grid-template-columns:
                    repeat(
                        2,
                        1fr
                    );

            }


            .payment-content {

                padding:
                    20px;

            }


            .form-row {

                grid-template-columns:
                    1fr;

            }

        }

    </style>

</head>


<body>


<!-- =====================================================
     TOP BAR
====================================================== -->

<div class="top-bar">

    🔒 Secure College Bus Fee Payment

</div>


<!-- =====================================================
     NAVBAR
====================================================== -->

<nav class="navbar">

    <div class="nav-container">


        <div class="nav-logo">

            <a href="/">

                Smart College Bus

            </a>

        </div>


        <div class="nav-actions">

            <a
                href="/student/dashboard"
                class="nav-btn"
            >

                <i class="fa-solid fa-house"></i>

                Dashboard

            </a>

        </div>

    </div>

</nav>


<!-- =====================================================
     MAIN PAYMENT PAGE
====================================================== -->

<main class="payment-page">


    <!-- =================================================
         HEADER
    ================================================== -->

    <div class="payment-heading">

        <h1>

            Complete Your Payment

        </h1>


        <p>

            Choose your preferred payment method
            to pay your college bus fee.

        </p>

    </div>


    <!-- =================================================
         PAYMENT LAYOUT
    ================================================== -->

    <div class="payment-layout">


        <!-- =================================================
             LEFT: FEE SUMMARY
        ================================================== -->

        <aside class="fee-summary">


            <h2>

                <i class="fa-solid fa-file-invoice"></i>

                Fee Summary

            </h2>


            <div class="student-info">


                <p>

                    <strong>
                        Student:
                    </strong>

                    <%= student.student_name %>

                </p>


                <p>

                    <strong>
                        Roll Number:
                    </strong>

                    <%= student.roll_number || 'N/A' %>

                </p>


                <p>

                    <strong>
                        Department:
                    </strong>

                    <%= student.department || 'N/A' %>

                </p>


                <p>

                    <strong>
                        Email:
                    </strong>

                    <%= student.email || 'N/A' %>

                </p>


            </div>


            <div class="fee-amount-box">


                <span>

                    Amount Payable

                </span>


                <div class="fee-amount">

                    ₹<%= Number(
                        fee.amount || 0
                    ).toFixed(2) %>

                </div>


            </div>


        </aside>


        <!-- =================================================
             RIGHT: PAYMENT
        ================================================== -->

        <section class="payment-container">


            <!-- =================================================
                 PAYMENT METHOD TABS
            ================================================== -->

            <div class="payment-methods">


                <button
                    type="button"
                    class="method-button active"
                    data-method="upi"
                >

                    <i class="fa-solid fa-mobile-screen-button"></i>

                    UPI

                </button>


                <button
                    type="button"
                    class="method-button"
                    data-method="card"
                >

                    <i class="fa-solid fa-credit-card"></i>

                    Card

                </button>


                <button
                    type="button"
                    class="method-button"
                    data-method="netbanking"
                >

                    <i class="fa-solid fa-building-columns"></i>

                    Net Banking

                </button>


                <button
                    type="button"
                    class="method-button"
                    data-method="wallet"
                >

                    <i class="fa-solid fa-wallet"></i>

                    Wallet

                </button>


                <button
                    type="button"
                    class="method-button"
                    data-method="rtgs"
                >

                    <i class="fa-solid fa-building-columns"></i>

                    RTGS / NEFT

                </button>


            </div>


            <!-- =================================================
                 PAYMENT CONTENT
            ================================================== -->

            <div class="payment-content">


                <!-- ERROR MESSAGE -->

                <div
                    id="errorMessage"
                    class="error-message"
                ></div>


                <!-- =================================================
                     UPI
                ================================================== -->

                <div
                    class="payment-box active"
                    id="payment-upi"
                >


                    <h2>

                        <i class="fa-solid fa-mobile-screen-button"></i>

                        UPI Payment

                    </h2>


                    <p class="payment-box-description">

                        Pay using any UPI application or scan
                        the QR code below.

                    </p>


                    <div class="simulation-notice">

                        <i class="fa-solid fa-flask"></i>

                        <strong>
                            Demo Payment Mode:
                        </strong>

                        This is a simulated payment system.
                        No real money will be transferred.

                    </div>


                    <div class="upi-layout">


                        <div>


                            <div class="upi-id-box">

                                <strong>
                                    UPI ID:
                                </strong>

                                abhisheksapkale06@pingpay

                            </div>


                            <div class="form-group">

                                <label>

                                    Enter UPI ID

                                </label>


                                <input
                                    type="text"
                                    id="upi_id"
                                    placeholder="example@upi"
                                >

                            </div>


                            <div class="form-group">

                                <label>

                                    UTR / Transaction Reference
                                    <small>
                                        (Optional for demo)
                                    </small>

                                </label>


                                <input
                                    type="text"
                                    id="upi_utr"
                                    placeholder="Enter UTR number"
                                >

                            </div>


                        </div>


                        <!-- QR CODE -->

                        <div class="qr-box">


                            <!--
                            Replace this image URL with your
                            own college UPI QR image later.
                            -->


                            <img
                                src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=upi://pay?pa=collegebus@upi%26pn=Smart%20College%20Bus"
                                alt="UPI QR Code"
                            >


                            <p>

                                Scan with any UPI app

                            </p>


                        </div>


                    </div>


                    <button
                        type="button"
                        class="pay-button"
                        data-method="UPI"
                    >

                        <i class="fa-solid fa-lock"></i>

                        Pay ₹<%= Number(
                            fee.amount || 0
                        ).toFixed(2) %>

                    </button>


                </div>


                <!-- =================================================
                     CARD
                ================================================== -->

                <div
                    class="payment-box"
                    id="payment-card"
                >


                    <h2>

                        <i class="fa-solid fa-credit-card"></i>

                        Credit / Debit Card

                    </h2>


                    <p class="payment-box-description">

                        Enter your card details for the
                        simulated payment.

                    </p>


                    <div class="simulation-notice">

                        <i class="fa-solid fa-flask"></i>

                        This is a demo payment.
                        Do not enter real card details.

                    </div>


                    <div class="card-logos">

                        <span class="card-logo">
                            VISA
                        </span>

                        <span class="card-logo">
                            Mastercard
                        </span>

                        <span class="card-logo">
                            RuPay
                        </span>

                        <span class="card-logo">
                            AMEX
                        </span>

                    </div>


                    <div class="form-group">

                        <label>
                            Cardholder Name
                        </label>

                        <input
                            type="text"
                            id="card_name"
                            placeholder="Enter cardholder name"
                        >

                    </div>


                    <div class="form-group">

                        <label>
                            Card Number
                        </label>

                        <input
                            type="text"
                            id="card_number"
                            maxlength="16"
                            inputmode="numeric"
                            placeholder="1234567890123456"
                        >

                    </div>


                    <div class="form-row">


                        <div class="form-group">

                            <label>
                                Expiry Date
                            </label>

                            <input
                                type="text"
                                id="card_expiry"
                                placeholder="MM/YY"
                                maxlength="5"
                            >

                        </div>


                        <div class="form-group">

                            <label>
                                CVV
                            </label>

                            <input
                                type="password"
                                id="card_cvv"
                                maxlength="3"
                                inputmode="numeric"
                                placeholder="123"
                            >

                        </div>


                    </div>


                    <button
                        type="button"
                        class="pay-button"
                        data-method="CARD"
                    >

                        <i class="fa-solid fa-lock"></i>

                        Pay ₹<%= Number(
                            fee.amount || 0
                        ).toFixed(2) %>

                    </button>


                </div>


                <!-- =================================================
                     NET BANKING
                ================================================== -->

                <div
                    class="payment-box"
                    id="payment-netbanking"
                >


                    <h2>

                        <i class="fa-solid fa-building-columns"></i>

                        Net Banking

                    </h2>


                    <p class="payment-box-description">

                        Select your bank to continue.

                    </p>


                    <div class="simulation-notice">

                        <i class="fa-solid fa-flask"></i>

                        This is a simulated payment.
                        No actual bank transaction will occur.

                    </div>


                    <div class="form-group">

                        <label>

                            Select Bank

                        </label>


                        <select id="bank_name">

                            <option value="">

                                Select your bank

                            </option>

                            <option value="SBI">

                                State Bank of India

                            </option>

                            <option value="HDFC">

                                HDFC Bank

                            </option>

                            <option value="ICICI">

                                ICICI Bank

                            </option>

                            <option value="AXIS">

                                Axis Bank

                            </option>

                            <option value="OTHER">

                                Other Bank

                            </option>

                        </select>

                    </div>


                    <button
                        type="button"
                        class="pay-button"
                        data-method="NETBANKING"
                    >

                        Continue to Payment

                    </button>


                </div>


                <!-- =================================================
                     WALLET
                ================================================== -->

                <div
                    class="payment-box"
                    id="payment-wallet"
                >


                    <h2>

                        <i class="fa-solid fa-wallet"></i>

                        Wallet Payment

                    </h2>


                    <p class="payment-box-description">

                        Select your preferred digital wallet.

                    </p>


                    <div class="simulation-notice">

                        <i class="fa-solid fa-flask"></i>

                        Demo mode: No real money will be deducted.

                    </div>


                    <div class="form-group">

                        <label>

                            Select Wallet

                        </label>


                        <select id="wallet_name">

                            <option value="">

                                Select Wallet

                            </option>

                            <option value="Paytm">

                                Paytm

                            </option>

                            <option value="PhonePe">

                                PhonePe

                            </option>

                            <option value="Google Pay">

                                Google Pay

                            </option>

                            <option value="Amazon Pay">

                                Amazon Pay

                            </option>

                        </select>

                    </div>


                    <button
                        type="button"
                        class="pay-button"
                        data-method="WALLET"
                    >

                        Pay ₹<%= Number(
                            fee.amount || 0
                        ).toFixed(2) %>

                    </button>


                </div>


                <!-- =================================================
                     RTGS / NEFT
                ================================================== -->

                <div
                    class="payment-box"
                    id="payment-rtgs"
                >


                    <h2>

                        <i class="fa-solid fa-building-columns"></i>

                        RTGS / NEFT

                    </h2>


                    <p class="payment-box-description">

                        Enter the bank transfer reference
                        number for simulated verification.

                    </p>


                    <div class="info-box">

                        <strong>
                            Bank Transfer Details
                        </strong>

                        <br><br>

                        Account Name:
                        Smart College Bus Management

                        <br>

                        Account Number:
                        1234567890

                        <br>

                        IFSC:
                        SBIN0000000

                        <br>

                        Bank:
                        State Bank of India

                    </div>


                    <div class="simulation-notice">

                        <i class="fa-solid fa-flask"></i>

                        Demo mode: The transfer is simulated
                        and will be marked successful immediately.

                    </div>


                    <div class="form-group">

                        <label>

                            UTR / Transfer Reference Number

                        </label>


                        <input
                            type="text"
                            id="rtgs_utr"
                            placeholder="Enter transfer reference"
                        >

                    </div>


                    <button
                        type="button"
                        class="pay-button"
                        data-method="RTGS_NEFT"
                    >

                        Confirm Bank Transfer

                    </button>


                </div>


                <!-- =================================================
                     PROCESSING MESSAGE
                ================================================== -->

                <div
                    id="processingMessage"
                    class="processing-message"
                >

                    <i class="fa-solid fa-spinner fa-spin"></i>

                    Processing simulated payment...
                    Please wait.

                </div>


            </div>


        </section>


    </div>


</main>


<!-- =====================================================
     JAVASCRIPT
====================================================== -->

<script>


/*
=========================================================
PAYMENT DATA
=========================================================
*/

const feeId =
    '<%= fee.id %>';


/*
=========================================================
METHOD BUTTONS
=========================================================
*/

const methodButtons =
    document.querySelectorAll(
        '.method-button'
    );


const paymentBoxes =
    document.querySelectorAll(
        '.payment-box'
    );


methodButtons.forEach(
    button => {

        button.addEventListener(
            'click',
            () => {


                /*
                =============================================
                REMOVE ACTIVE STATE
                =============================================
                */

                methodButtons.forEach(
                    btn => {

                        btn.classList.remove(
                            'active'
                        );

                    }
                );


                /*
                =============================================
                ADD ACTIVE STATE
                =============================================
                */

                button.classList.add(
                    'active'
                );


                /*
                =============================================
                HIDE ALL PAYMENT BOXES
                =============================================
                */

                paymentBoxes.forEach(
                    box => {

                        box.classList.remove(
                            'active'
                        );

                    }
                );


                /*
                =============================================
                SHOW SELECTED PAYMENT BOX
                =============================================
                */

                const method =
                    button.dataset.method;


                const selectedBox =
                    document.getElementById(
                        `payment-${method}`
                    );


                if (selectedBox) {

                    selectedBox.classList.add(
                        'active'
                    );

                }

            }
        );

    }
);


/*
=========================================================
ELEMENTS
=========================================================
*/

const payButtons =
    document.querySelectorAll(
        '.pay-button'
    );


const errorMessage =
    document.getElementById(
        'errorMessage'
    );


const processingMessage =
    document.getElementById(
        'processingMessage'
    );


/*
=========================================================
SHOW ERROR
=========================================================
*/

function showError(
    message
) {

    errorMessage.textContent =
        message;

    errorMessage.classList.add(
        'show'
    );

}


/*
=========================================================
HIDE ERROR
=========================================================
*/

function hideError() {

    errorMessage.textContent =
        '';

    errorMessage.classList.remove(
        'show'
    );

}


/*
=========================================================
GET PAYMENT DATA
=========================================================
*/

function getPaymentData(
    method
) {


    const data = {

        payment_method:
            method

    };


    /*
    =====================================================
    UPI
    =====================================================
    */

    if (
        method === 'UPI'
    ) {

        data.upi_id =

            document
                .getElementById(
                    'upi_id'
                )
                .value
                .trim();


        data.utr_number =

            document
                .getElementById(
                    'upi_utr'
                )
                .value
                .trim();

    }


    /*
    =====================================================
    CARD
    =====================================================
    */

    if (
        method === 'CARD'
    ) {

        data.card_number =

            document
                .getElementById(
                    'card_number'
                )
                .value
                .trim();


        data.card_name =

            document
                .getElementById(
                    'card_name'
                )
                .value
                .trim();


        data.card_expiry =

            document
                .getElementById(
                    'card_expiry'
                )
                .value
                .trim();


        data.card_cvv =

            document
                .getElementById(
                    'card_cvv'
                )
                .value
                .trim();

    }


    /*
    =====================================================
    NET BANKING
    =====================================================
    */

    if (
        method === 'NETBANKING'
    ) {

        data.bank_name =

            document
                .getElementById(
                    'bank_name'
                )
                .value;

    }


    /*
    =====================================================
    WALLET
    =====================================================
    */

    if (
        method === 'WALLET'
    ) {

        data.wallet_name =

            document
                .getElementById(
                    'wallet_name'
                )
                .value;

    }


    /*
    =====================================================
    RTGS / NEFT
    =====================================================
    */

    if (
        method === 'RTGS_NEFT'
    ) {

        data.utr_number =

            document
                .getElementById(
                    'rtgs_utr'
                )
                .value
                .trim();

    }


    return data;

}


/*
=========================================================
VALIDATE PAYMENT
=========================================================
*/

function validatePayment(
    method,
    data
) {


    /*
    =====================================================
    UPI
    =====================================================
    */

    if (
        method === 'UPI'
    ) {

        if (
            !data.upi_id &&
            !data.utr_number
        ) {

            return 'Please enter your UPI ID or UTR number.';

        }

    }


    /*
    =====================================================
    CARD
    =====================================================
    */

    if (
        method === 'CARD'
    ) {

        if (
            !data.card_name
        ) {

            return 'Please enter the cardholder name.';

        }


        if (
            !/^\d{16}$/.test(
                data.card_number
            )
        ) {

            return 'Please enter a valid 16-digit demo card number.';

        }


        if (
            !data.card_expiry
        ) {

            return 'Please enter the card expiry date.';

        }


        if (
            !/^\d{3}$/.test(
                data.card_cvv
            )
        ) {

            return 'Please enter a valid 3-digit CVV.';

        }

    }


    /*
    =====================================================
    NET BANKING
    =====================================================
    */

    if (
        method === 'NETBANKING'
    ) {

        if (
            !data.bank_name
        ) {

            return 'Please select a bank.';

        }

    }


    /*
    =====================================================
    WALLET
    =====================================================
    */

    if (
        method === 'WALLET'
    ) {

        if (
            !data.wallet_name
        ) {

            return 'Please select a wallet.';

        }

    }


    /*
    =====================================================
    RTGS / NEFT
    =====================================================
    */

    if (
        method === 'RTGS_NEFT'
    ) {

        if (
            !data.utr_number
        ) {

            return 'Please enter the UTR / transfer reference number.';

        }

    }


    return null;

}


/*
=========================================================
PROCESS PAYMENT
=========================================================
*/

payButtons.forEach(

    button => {


        button.addEventListener(

            'click',

            async () => {


                /*
                =============================================
                HIDE PREVIOUS ERROR
                =============================================
                */

                hideError();


                /*
                =============================================
                GET METHOD
                =============================================
                */

                const method =
                    button.dataset.method;


                /*
                =============================================
                GET DATA
                =============================================
                */

                const paymentData =
                    getPaymentData(
                        method
                    );


                /*
                =============================================
                VALIDATE
                =============================================
                */

                const validationError =
                    validatePayment(
                        method,
                        paymentData
                    );


                if (
                    validationError
                ) {

                    showError(
                        validationError
                    );

                    return;

                }


                /*
                =============================================
                DISABLE ALL BUTTONS
                =============================================
                */

                payButtons.forEach(
                    btn => {

                        btn.disabled =
                            true;

                    }
                );


                /*
                =============================================
                SHOW PROCESSING
                =============================================
                */

                processingMessage.classList.add(
                    'show'
                );


                try {


                    /*
                    =========================================
                    SEND PAYMENT TO BACKEND
                    =========================================
                    */

                    const response =
                        await fetch(

                            `/payment/${feeId}/pay`,

                            {

                                method:
                                    'POST',

                                headers: {

                                    'Content-Type':
                                        'application/json'

                                },

                                body:
                                    JSON.stringify(
                                        paymentData
                                    )

                            }

                        );


                    /*
                    =========================================
                    READ RESPONSE
                    =========================================
                    */

                    const result =
                        await response.json();


                    /*
                    =========================================
                    PAYMENT FAILED
                    =========================================
                    */

                    if (
                        !response.ok ||
                        !result.success
                    ) {

                        throw new Error(

                            result.message ||

                            'Payment failed.'

                        );

                    }


                    /*
                    =========================================
                    SUCCESS
                    =========================================
                    */

                    window.location.href =

                        `/payment/success/${result.paymentId}`;


                } catch (
                    error
                ) {


                    console.error(

                        'Payment error:',

                        error

                    );


                    /*
                    =========================================
                    SHOW ERROR
                    =========================================
                    */

                    showError(

                        error.message ||

                        'Unable to process payment.'

                    );


                    /*
                    =========================================
                    ENABLE BUTTONS AGAIN
                    =========================================
                    */

                    payButtons.forEach(
                        btn => {

                            btn.disabled =
                                false;

                        }
                    );


                    /*
                    =========================================
                    HIDE PROCESSING
                    =========================================
                    */

                    processingMessage.classList.remove(
                        'show'
                    );

                }

            }

        );

    }


);


</script>


</body>

</html>
