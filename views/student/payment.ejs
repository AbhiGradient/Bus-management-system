<%- include('../partials/header', {
  pageTitle: 'Pay Fees',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'fee-status'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Pay Fees'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <!-- ================= PAGE HEADER ================= -->

      <div class="d-flex justify-content-between align-items-center mb-3">

        <h3>
          <i class="bi bi-credit-card-2-front"></i>
          Complete Your Payment
        </h3>

        <a href="/student/fees-status" class="btn btn-secondary btn-sm">
          <i class="bi bi-arrow-left"></i>
          Back to Fees
        </a>

      </div>


      <!-- ================= ERROR ================= -->

      <% if (error) { %>

        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <%= error %>
        </div>

      <% } %>


      <div class="row g-3">


        <!-- ================================================= -->
        <!-- LEFT: PAYMENT METHODS -->
        <!-- ================================================= -->

        <div class="col-lg-3">

          <div class="card p-3 h-100">

            <p class="fw-bold mb-3" style="color:var(--ink-hi);">
              Payment Methods
            </p>


            <!-- UPI BUTTON -->

            <button
              type="button"
              class="pay-option active"
              data-target="method-upi"
            >
              <i class="bi bi-phone"></i>
              UPI
            </button>


            <!-- QR BUTTON -->

            <button
              type="button"
              class="pay-option"
              data-target="method-qr"
            >
              <i class="bi bi-qr-code"></i>
              QR Code
            </button>


            <!-- CARD -->

            <button
              type="button"
              class="pay-option"
              disabled
              title="Coming soon"
            >
              <i class="bi bi-credit-card"></i>
              Card

              <span
                class="badge-status"
                style="float:right; font-size:10px;"
              >
                Soon
              </span>

            </button>


            <!-- NET BANKING -->

            <button
              type="button"
              class="pay-option"
              disabled
              title="Coming soon"
            >
              <i class="bi bi-bank"></i>
              Net Banking

              <span
                class="badge-status"
                style="float:right; font-size:10px;"
              >
                Soon
              </span>

            </button>

          </div>

        </div>


        <!-- ================================================= -->
        <!-- RIGHT: PAYMENT BOX -->
        <!-- ================================================= -->

        <div class="col-lg-9">

          <div class="card p-4">

            <div class="row g-4">


              <!-- ================================================= -->
              <!-- STUDENT & FEE DETAILS -->
              <!-- ================================================= -->

              <div class="col-md-6">

                <h5 class="mb-3">
                  <i class="bi bi-person-badge"></i>
                  Student Details
                </h5>


                <table class="table table-borderless mb-0">

                  <tbody>

                    <tr>

                      <td
                        class="text-muted"
                        style="width:45%;"
                      >
                        Name
                      </td>

                      <td class="fw-semibold">
                        <%= user.name %>
                      </td>

                    </tr>


                    <tr>

                      <td class="text-muted">
                        Roll Number
                      </td>

                      <td class="fw-semibold">
                        <%= student.roll_no %>
                      </td>

                    </tr>


                    <tr>

                      <td class="text-muted">
                        Bus Route
                      </td>

                      <td class="fw-semibold">
                        <%= bus ? bus.route_name : 'Not Assigned' %>
                      </td>

                    </tr>


                    <tr>

                      <td class="text-muted">
                        Bus Number
                      </td>

                      <td class="fw-semibold">
                        <%= bus ? bus.bus_number : '—' %>
                      </td>

                    </tr>


                    <tr>

                      <td class="text-muted">
                        Due Date
                      </td>

                      <td class="fw-semibold">

                        <%= fee.due_date
                          ? new Date(fee.due_date).toLocaleDateString('en-IN')
                          : '—'
                        %>

                      </td>

                    </tr>

                  </tbody>

                </table>


                <!-- PENDING FEE -->

                <div
                  class="mt-3 p-3"
                  style="
                    background:var(--paper-sunk);
                    border-radius:var(--radius-md);
                    border:1px solid var(--line);
                  "
                >

                  <div
                    class="d-flex justify-content-between align-items-center"
                  >

                    <span class="text-muted">
                      Pending Fee
                    </span>

                    <h4
                      class="mb-0"
                      style="color:var(--pine);"
                    >
                      ₹<%= Number(fee.amount || 0).toLocaleString('en-IN') %>
                    </h4>

                  </div>

                </div>

              </div>


              <!-- ================================================= -->
              <!-- PAYMENT PANEL -->
              <!-- ================================================= -->

              <div class="col-md-6">


                <!-- ================= UPI ================= -->

                <div
                  id="method-upi"
                  class="payment-method-box"
                >

                  <h5 class="mb-3">

                    <i class="bi bi-phone"></i>

                    Pay via UPI

                  </h5>


                  <div
                    class="p-3 mb-3"
                    style="
                      background:var(--paper-sunk);
                      border-radius:var(--radius-md);
                      border:1px dashed var(--line);
                    "
                  >

                    <p
                      class="text-muted mb-1"
                      style="font-size:12.5px;"
                    >
                      Send payment to UPI ID
                    </p>


                    <p
                      class="fw-bold mb-0"
                      style="
                        font-family:var(--font-mono);
                        color:var(--pine-deep);
                        font-size:15px;
                      "
                    >
                      <%= upiId %>
                    </p>

                  </div>


                  <div class="alert alert-info">

                    <i class="bi bi-info-circle"></i>

                    Open your UPI app and send

                    <strong>
                      ₹<%= Number(fee.amount || 0).toLocaleString('en-IN') %>
                    </strong>

                    to the UPI ID above.

                  </div>

                </div>


                <!-- ================= QR CODE ================= -->

                <div
                  id="method-qr"
                  class="payment-method-box"
                  style="display:none;"
                >

                  <h5 class="mb-3">

                    <i class="bi bi-qr-code"></i>

                    Scan &amp; Pay

                  </h5>


                  <div
                    class="text-center p-3 mb-3"
                    style="
                      background:var(--paper-sunk);
                      border-radius:var(--radius-md);
                      border:1px solid var(--line);
                    "
                  >

                    <img
                      src="<%= qrImagePath %>"
                      alt="College Payment QR Code"
                      style="
                        max-width:220px;
                        width:100%;
                        border-radius:8px;
                      "
                      onerror="
                        this.style.display='none';
                        document.getElementById('qrError').style.display='block';
                      "
                    />


                    <!-- QR ERROR -->

                    <div
                      id="qrError"
                      class="alert alert-danger mt-2"
                      style="display:none;"
                    >

                      <i class="bi bi-exclamation-triangle"></i>

                      QR Code image could not be loaded.

                    </div>


                    <p
                      class="text-muted mt-2 mb-0"
                      style="font-size:12px;"
                    >

                      Scan with any UPI app to pay

                      <strong>
                        ₹<%= Number(fee.amount || 0).toLocaleString('en-IN') %>
                      </strong>

                    </p>

                  </div>

                </div>


                <!-- ================================================= -->
                <!-- PAYMENT CONFIRMATION -->
                <!-- ================================================= -->

                <form
                  action="/payment/<%= fee.id %>/confirm"
                  method="POST"
                  id="paymentForm"
                >

                  <div class="mb-3">

                    <label class="form-label">

                      Transaction ID / UTR Number

                    </label>


                    <input
                      type="text"
                      name="utr"
                      class="form-control"
                      placeholder="e.g. 402913485712"
                      maxlength="30"
                      required
                    />


                    <small class="text-muted">

                      Enter the UTR / Transaction ID shown in your UPI app after paying.

                    </small>

                  </div>


                  <button
                    type="submit"
                    class="btn btn-success w-100"
                    id="confirmPayBtn"
                  >

                    <i class="bi bi-check-circle-fill"></i>

                    I Have Paid

                  </button>

                </form>


              </div>

            </div>

          </div>

        </div>

      </div>

    </main>


    <!-- FOOTER -->

    <%- include('../partials/footer') %>

  </div>

</div>


<!-- ================================================= -->
<!-- STYLES -->
<!-- ================================================= -->

<style>

  .pay-option {

    width: 100%;

    background: var(--paper-sunk);

    border: 1px solid var(--line);

    color: var(--ink-mid);

    padding: 12px 14px;

    border-radius: var(--radius-sm);

    text-align: left;

    cursor: pointer;

    margin-bottom: 10px;

    font-weight: 600;

    font-size: 14px;

    transition:
      background .2s,
      color .2s,
      transform .2s;

  }


  .pay-option:hover:not(:disabled) {

    transform: translateY(-2px);

  }


  .pay-option.active {

    background:
      linear-gradient(
        135deg,
        var(--pine),
        var(--pine-deep)
      );

    color: #fff;

    border-color: var(--pine);

  }


  .pay-option:disabled {

    opacity: 0.5;

    cursor: not-allowed;

  }


  .payment-method-box {

    animation: fadeIn .2s ease;

  }


  @keyframes fadeIn {

    from {

      opacity: 0;

      transform: translateY(5px);

    }

    to {

      opacity: 1;

      transform: translateY(0);

    }

  }

</style>


<!-- ================================================= -->
<!-- SCRIPTS -->
<!-- ================================================= -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/script.js"></script>


<!-- ================================================= -->
<!-- UPI / QR TOGGLE -->
<!-- ================================================= -->

<script>

document.addEventListener('DOMContentLoaded', function () {

  const paymentButtons =
    document.querySelectorAll('.pay-option[data-target]');


  const paymentPanels =
    document.querySelectorAll('.payment-method-box');


  paymentButtons.forEach(function (button) {

    button.addEventListener('click', function () {

      const targetId =
        this.getAttribute('data-target');


      // Remove active state from all buttons

      paymentButtons.forEach(function (btn) {

        btn.classList.remove('active');

      });


      // Add active state to clicked button

      this.classList.add('active');


      // Hide all payment panels

      paymentPanels.forEach(function (panel) {

        panel.style.display = 'none';

      });


      // Show selected panel

      const targetPanel =
        document.getElementById(targetId);


      if (targetPanel) {

        targetPanel.style.display = 'block';

      }

    });

  });

});

</script>


<!-- ================================================= -->
<!-- CONFIRM PAYMENT BUTTON -->
<!-- ================================================= -->

<script>

document.addEventListener('DOMContentLoaded', function () {

  const paymentForm =
    document.getElementById('paymentForm');


  const confirmButton =
    document.getElementById('confirmPayBtn');


  if (paymentForm && confirmButton) {

    paymentForm.addEventListener('submit', function () {

      confirmButton.disabled = true;


      confirmButton.innerHTML =
        '<span class="spinner-border spinner-border-sm"></span> Processing...';

    });

  }

});

</script>


</body>

</html>