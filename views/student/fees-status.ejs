<%- include('../partials/header', {
  pageTitle: 'Fee Status',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'fee-status'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Fee Status'
  }) %>

  <div class="app-main">

    <main class="main-content">

      <!-- PAGE HEADER -->
      <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
          <h3 class="mb-1">
            <i class="bi bi-cash-coin text-warning"></i>
            My Fee Status
          </h3>

          <p class="text-muted mb-0">
            View your transport fee details and make payments.
          </p>
        </div>

        <a
          href="/student/payment-history"
          class="btn btn-outline-primary btn-sm"
        >
          <i class="bi bi-clock-history"></i>
          Payment History
        </a>

      </div>


      <!-- SUMMARY CARDS -->
      <div class="row g-3 mb-4">

        <!-- TOTAL -->
        <div class="col-md-4">

          <div class="card p-3 text-center h-100">

            <div class="text-muted small">
              Total Amount
            </div>

            <div class="fs-3 fw-bold">
              ₹<%= Number(totalAmount || 0).toLocaleString('en-IN') %>
            </div>

          </div>

        </div>


        <!-- PAID -->
        <div class="col-md-4">

          <div class="card p-3 text-center h-100">

            <div class="text-muted small">
              Paid
            </div>

            <div class="fs-3 fw-bold text-success">
              ₹<%= Number(paidAmount || 0).toLocaleString('en-IN') %>
            </div>

          </div>

        </div>


        <!-- UNPAID -->
        <div class="col-md-4">

          <div class="card p-3 text-center h-100">

            <div class="text-muted small">
              Unpaid
            </div>

            <div class="fs-3 fw-bold text-danger">
              ₹<%= Number(unpaidAmount || 0).toLocaleString('en-IN') %>
            </div>

          </div>

        </div>

      </div>


      <!-- FEE HISTORY -->
      <div class="card p-3">

        <div class="d-flex justify-content-between align-items-center mb-3">

          <h5 class="mb-0">
            <i class="bi bi-clock-history"></i>
            Fee History
          </h5>

          <span class="text-muted small">
            <%= fees ? fees.length : 0 %> Record(s)
          </span>

        </div>


        <div class="table-responsive">

          <table class="table table-hover align-middle">

            <thead>

              <tr>

                <th>#</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Due Date</th>
                <th>Paid Date</th>
                <th class="text-center">Action</th>

              </tr>

            </thead>


            <tbody>

              <% if (!fees || fees.length === 0) { %>

                <tr>

                  <td
                    colspan="6"
                    class="text-center text-muted py-5"
                  >

                    <i
                      class="bi bi-receipt"
                      style="font-size: 2rem;"
                    ></i>

                    <div class="mt-2">
                      No fee records found.
                    </div>

                  </td>

                </tr>

              <% } else { %>


                <% fees.forEach((f, i) => { %>

                  <tr>

                    <!-- NUMBER -->
                    <td>
                      <%= i + 1 %>
                    </td>


                    <!-- AMOUNT -->
                    <td>

                      <strong>
                        ₹<%= Number(f.amount || 0).toLocaleString('en-IN') %>
                      </strong>

                    </td>


                    <!-- STATUS -->
                    <td>

                      <% if (f.status === 'paid') { %>

                        <span class="badge bg-success">

                          <i class="bi bi-check-circle-fill"></i>

                          Paid

                        </span>

                      <% } else { %>

                        <span class="badge bg-danger">

                          <i class="bi bi-exclamation-circle-fill"></i>

                          Unpaid

                        </span>

                      <% } %>

                    </td>


                    <!-- DUE DATE -->
                    <td>

                      <%= f.due_date
                        ? new Date(f.due_date).toLocaleDateString('en-IN')
                        : '—'
                      %>

                    </td>


                    <!-- PAID DATE -->
                    <td>

                      <%= f.paid_date
                        ? new Date(f.paid_date).toLocaleDateString('en-IN')
                        : '—'
                      %>

                    </td>


                    <!-- ACTION -->
                    <td class="text-center">

                      <% if (f.status === 'unpaid') { %>

                        <a
                          href="/payment/<%= f.id %>"
                          class="btn btn-primary btn-sm"
                        >

                          <i class="bi bi-credit-card"></i>

                          Pay Now

                        </a>

                      <% } else { %>

                        <span class="text-success fw-semibold">

                          <i class="bi bi-check-circle-fill"></i>

                          Paid

                        </span>

                      <% } %>

                    </td>

                  </tr>

                <% }) %>

              <% } %>

            </tbody>

          </table>

        </div>

      </div>

    </main>


    <%- include('../partials/footer') %>

  </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/script.js"></script>

</body>
</html>