<%- include('../partials/header', {
  pageTitle: 'Notifications',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'notifications'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Notifications'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <h3 class="mb-3">
        <i class="bi bi-bell-fill text-warning"></i>
        Notifications
      </h3>

      <div class="card p-3">

        <% if (notifications.length === 0) { %>

          <p class="text-muted text-center py-3 mb-0">You have no notifications right now.</p>

        <% } else { %>

          <ul class="list-group list-group-flush">
            <% notifications.forEach(n => { %>
              <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium"><%= n.title %></div>
                    <div class="text-muted small mt-1"><%= n.message %></div>
                  </div>
                  <span class="text-muted small text-nowrap ms-3">
                    <%= new Date(n.created_at).toLocaleDateString('en-IN') %>
                  </span>
                </div>
              </li>
            <% }) %>
          </ul>

        <% } %>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
