<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Seat Management | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
  <link href="/css/seat-management.css" rel="stylesheet">
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/seat-management"><i class="bi bi-grid-3x3-gap-fill"></i>Seat Management </a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <h3 class="mb-3">
    <i class="bi bi-grid-3x3-gap-fill"></i>
    Seat Management
</h3>
<div class="card p-4 mt-3">

    <h4>Assign Seat</h4>

    <div class="row">

        <div class="col-md-4">
            <label>Select Bus</label>
            <select class="form-select">
                <% buses.forEach(bus => { %>
                    <option value="<%= bus.id %>">
                       <%= bus.bus_number %>
                    </option>
                <% }) %>
</select>
        </div>

        <div class="col-md-4">
            <label>Select Student</label>
            <select class="form-select">
                <% students.forEach(student => { %>
                   <option value="<%= student.id %>">
                      <%= student.roll_no %>
                   </option>
                <% }) %>
</select>
        </div>

        <div class="col-md-4">
            <label>Select Seat</label>
            <select class="form-select">
                <option>Choose Seat</option>
            </select>
        </div>

    </div>

    <button class="btn btn-primary mt-4">
        Assign Seat
    </button>

</div>
    

      <footer class="app-footer">Smart College Bus Management System &copy; <%= new Date().getFullYear() %></footer>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
  <script src="/js/seat-management.js"></script>
</body>
</html>
