<%- include('../partials/header', { pageTitle: 'Forgot Password', pageCss: ['login'] }) %>

<div class="login-shell">

  <!-- LEFT PANEL -->
  <div class="login-side">

    <div class="brand">
      <div class="brand-mark">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="6" width="18" height="12" rx="2"/>
          <path d="M3 10h18"/>
        </svg>
      </div>
      <strong>CampusTransit</strong>
    </div>

    <div class="pitch">
      <div class="eyebrow">
        Smart College Bus Management
      </div>

      <h1>
        Recover your account and get back on your route.
      </h1>

      <p>
        Enter your registered college email address and we'll send you a secure
        password reset link. The same process works for administrators,
        students and drivers.
      </p>
    </div>

    <div class="login-route-art">
      <svg viewBox="0 0 460 90" fill="none" xmlns="http://www.w3.org/2000/svg">

        <path
          d="M20 65 C 120 65, 140 20, 230 20 S 340 65, 440 65"
          stroke="rgba(184,134,60,0.55)"
          stroke-width="2"
          stroke-dasharray="1 10"
          stroke-linecap="round"/>

        <circle cx="20" cy="65" r="5" fill="#B8863C"/>
        <circle cx="230" cy="20" r="5" fill="#B8863C"/>
        <circle cx="440" cy="65" r="5" fill="#B8863C"/>

        <g transform="translate(150,4)">
          <rect x="0" y="0" width="34" height="20" rx="4" fill="#F6F3EC" fill-opacity="0.14"/>
          <rect x="4" y="4" width="10" height="7" rx="1" fill="#F6F3EC" fill-opacity="0.5"/>
          <rect x="17" y="4" width="10" height="7" rx="1" fill="#F6F3EC" fill-opacity="0.5"/>
          <circle cx="8" cy="17" r="2" fill="#F6F3EC" fill-opacity="0.5"/>
          <circle cx="26" cy="17" r="2" fill="#F6F3EC" fill-opacity="0.5"/>
        </g>

      </svg>
    </div>

    <div class="route-stops">
      <div class="stop">
        <span class="dot"></span>
        <strong>Secure</strong>&nbsp;password recovery
      </div>

      <div class="stop">
        <span class="dot"></span>
        <strong>30 minute</strong>&nbsp;reset link
      </div>

      <div class="stop">
        <span class="dot"></span>
        <strong>Works for</strong>&nbsp;Admin, Student & Driver
      </div>
    </div>

  </div>

  <!-- RIGHT PANEL -->

  <div class="login-form-side">

    <div class="login-ticket ticket-card">

      <div class="ticket-head">

        <div style="display:flex;align-items:center;gap:14px;">

          <div class="ticket-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 17v1"/>
              <circle cx="12" cy="10" r="3"/>
              <path d="M7 10V8a5 5 0 0110 0v2"/>
              <rect x="5" y="10" width="14" height="10" rx="2"/>
            </svg>
          </div>

          <div>
            <div class="eyebrow">
              Password Recovery
            </div>

            <h1>
              Forgot Password
            </h1>

            <p>
              Reset your CampusTransit account
            </p>

          </div>

        </div>

      </div>

      <div class="ticket-tear"></div>

      <div class="ticket-body">

        <% if (typeof error !== 'undefined' && error) { %>

          <div class="alert alert-danger mb-3">
            <%= error %>
          </div>

        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>

          <div class="alert alert-success mb-3">
            <%= success %>
          </div>

        <% } %>

        <form action="/forgot-password" method="POST">

          <div class="field">

            <label for="email">
              Registered Email
            </label>

            <input
              class="input"
              type="email"
              id="email"
              name="email"
              placeholder="you@college.edu"
              required>

            <div class="hint">
              Enter the email used to sign into CampusTransit.
            </div>

          </div>

          <button class="btn btn-primary btn-block" type="submit">
            Send Reset Link
          </button>

        </form>

        <div
          style="
          margin-top:22px;
          text-align:center;
          ">

          <a
            href="/login"
            style="
            color:var(--pine);
            font-weight:600;
            text-decoration:none;
            ">

            ← Back to Login

          </a>

        </div>

        <p class="login-foot-note">

          Need help?

          <a href="/home/contact">
            Contact the Transport Office
          </a>

        </p>

      </div>

    </div>

  </div>

</div>

</body>
</html>