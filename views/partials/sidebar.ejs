const navConfig = {
  admin: [
    {
      group: 'Overview',
      links: [
        { href: '/admin/dashboard', label: 'Dashboard', icon: 'grid', key: 'dashboard' }
      ]
    },
    {
      group: 'Fleet',
      links: [
        { href: '/admin/buses', label: 'Buses', icon: 'bus', key: 'buses' },
        { href: '/admin/assign-bus', label: 'Assign Bus', icon: 'route', key: 'assign-bus' },
        { href: '/tracking/live', label: 'Live Tracking', icon: 'pin', key: 'tracking' } // Future
      ]
    },
    {
      group: 'People',
      links: [
        { href: '/admin/students', label: 'Students', icon: 'users', key: 'students' },
        { href: '/admin/drivers', label: 'Drivers', icon: 'id', key: 'drivers' } // Future
      ]
    },
    {
      group: 'Operations',
      links: [
        { href: '/admin/seat-management', label: 'Seat Management', icon: 'seat', key: 'seat-management' }, // Future
        { href: '/admin/requests', label: 'Requests', icon: 'inbox', key: 'requests' },
        { href: '/admin/fees', label: 'Fees', icon: 'coin', key: 'fees' },
        { href: '/admin/reports', label: 'Reports', icon: 'chart', key: 'reports' }, // Future
        { href: '/admin/notifications', label: 'Notifications', icon: 'bell', key: 'notifications' } // Future
