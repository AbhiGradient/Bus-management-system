  student: [
    {
      group: 'Overview',
      links: [
        { href: '/student/dashboard', label: 'Dashboard', icon: 'grid', key: 'dashboard' }
      ]
    },
    {
      group: 'My Bus',
      links: [
        { href: '/student/bus-details', label: 'Bus Details', icon: 'bus', key: 'bus-details' }, // Future
        { href: '/student/seat-management', label: 'Seat Management', icon: 'seat', key: 'seat-management' }, // Future
        { href: '/tracking/live', label: 'Live Tracking', icon: 'pin', key: 'tracking' }, // Future
        { href: '/student/route-map', label: 'Route Map', icon: 'route', key: 'route-map' } // Future
      ]
    },
    {
      group: 'Attendance & Fees',
      links: [
        { href: '/student/attendance', label: 'Attendance', icon: 'clock', key: 'attendance' }, // Future
        { href: '/student/fees-status', label: 'Fee Status', icon: 'coin', key: 'fee-status' },
        { href: '/student/payment-history', label: 'Payment History', icon: 'card', key: 'payment-history' } // Future
      ]
    },
    {
      group: 'Requests',
      links: [
        { href: '/student/request-bus-change', label: 'Request Bus Change', icon: 'ticket', key: 'request-bus-change' }, // Future
        { href: '/student/requests', label: 'Request Status', icon: 'inbox', key: 'request-status' }
      ]
    },
    {
  group: 'Account',
  links: [
    { href: '/driver/profile', label: 'Profile', icon: 'user', key: 'profile' },
    { href: '/driver/notifications', label: 'Notifications', icon: 'bell', key: 'notifications' }
  ]
}
  ],

  driver: [
    {
      group: 'Overview',
      links: [
        { href: '/driver/dashboard', label: 'Dashboard', icon: 'grid', key: 'dashboard' }
      ]
    },
    {
      group: 'Today',
      links: [
        { href: '/driver/today-route', label: "Today's Route", icon: 'route', key: 'today-route' }, // Future
        { href: '/driver/trip-start', label: 'Start Trip', icon: 'bus', key: 'trip-start' }, // Future
        { href: '/driver/trip-end', label: 'End Trip', icon: 'ticket', key: 'trip-end' }, // Future
        { href: '/driver/live-location', label: 'Live Location', icon: 'pin', key: 'live-location' } // Future
      ]
    },
    {
      group: 'Students',
      links: [
        { href: '/driver/attendance', label: 'Attendance', icon: 'clock', key: 'attendance' } // Future
      ]
    },
    {
      group: 'Account',
      links: [
        { href: '/profile', label: 'Profile', icon: 'user', key: 'profile' },
        { href: '/driver/notifications', label: 'Notifications', icon: 'bell', key: 'notifications' } // Future
      ]
    }
  ]
};
const role = (typeof user !== 'undefined' && user && navConfig[user.role]) ? user.role : 'admin';
const active = typeof currentPage !== 'undefined' ? currentPage : '';
const groups = navConfig[role];
%>
<aside class="sidebar" id="appSidebar">
  <div class="sidebar-brand">
    <div class="brand-mark">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18"/></svg>
    </div>
    <div class="brand-text">
      <strong>CampusTransit</strong>
      <span><%= role %></span>
    </div>
  </div>
  <nav class="sidebar-scroll">
    <% groups.forEach(function (group) { %>
      <div class="sidebar-group">
        <div class="sidebar-group-label"><%= group.group %></div>
        <% group.links.forEach(function (link) { %>
          <a href="<%= link.href %>" class="sidebar-link<%= active === link.key ? ' active' : '' %>">
            <%- icons[link.icon] %>
            <span><%= link.label %></span>
          </a>
        <% }) %>
      </div>
    <% }) %>
  </nav>
  <div class="sidebar-foot">v1.0 &middot; CampusTransit</div>
</aside>
