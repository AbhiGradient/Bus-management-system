<%
/*
  views/partials/sidebar.ejs
  Include as the first child of .app-shell, before .app-main.

  Locals:
    currentPage (string) — the key of the link to highlight as active.
    res.locals.user is already available globally (set in server.js).

  Nav links are grouped per role below. If a page is shared across roles
  (e.g. seat-management, tracking) it appears in more than one role's list
  but always points at the SAME file/route — never duplicate the view.
  See CONTRIBUTING.md.
*/
