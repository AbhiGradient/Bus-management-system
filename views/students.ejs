<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Students | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people-fill"></i> Manage Students</h3>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStudentModal">
          <i class="bi bi-person-plus"></i> Add Student
        </button>
      </div>

      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Roll No</th>
                <th>Department</th>
                <th>Year</th>
                <th>Email</th>
                <th>Bus</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (students.length === 0) { %>
                <tr><td colspan="8" class="text-center text-muted py-3">No students added yet.</td></tr>
              <% } %>
              <% students.forEach((s, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= s.name %></td>
                  <td><%= s.roll_no %></td>
                  <td><%= s.department %></td>
                  <td><%= s.year %></td>
                  <td><%= s.email %></td>
                  <td><%= s.bus_number || '—' %></td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editStudentModal<%= s.id %>">
                      <i class="bi bi-pencil-square"></i>
                    </button>
                    <form action="/admin/students/<%= s.id %>?_method=DELETE" method="POST" class="d-inline confirm-delete">
                      <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  </td>
                </tr>

                <!-- Edit Modal -->
                <div class="modal fade" id="editStudentModal<%= s.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <form action="/admin/students/<%= s.id %>?_method=PUT" method="POST" class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Student</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <div class="modal-body">
                        <div class="mb-2">
                          <label class="form-label">Full Name</label>
                          <input type="text" name="name" class="form-control" value="<%= s.name %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Email</label>
                          <input type="email" name="email" class="form-control" value="<%= s.email %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Phone</label>
                          <input type="text" name="phone" class="form-control" value="<%= s.phone || '' %>" />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Roll No</label>
                          <input type="text" name="roll_no" class="form-control" value="<%= s.roll_no %>" required />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Department</label>
                          <input type="text" name="department" class="form-control" value="<%= s.department || '' %>" />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Year</label>
                          <input type="text" name="year" class="form-control" value="<%= s.year || '' %>" />
                        </div>
                        <div class="mb-2">
                          <label class="form-label">Address</label>
                          <textarea name="address" class="form-control" rows="2"><%= s.address || '' %></textarea>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                      </div>
                    </form>
                  </div>
                </div>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

       
    </div>
  </div>

  <!-- Add Student Modal -->
  <div class="modal fade" id="addStudentModal" tabindex="-1">
    <div class="modal-dialog">
      <form action="/admin/students" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add New Student</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-2">
            <label class="form-label">Full Name</label>
            <input type="text" name="name" class="form-control" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Phone</label>
            <input type="text" name="phone" class="form-control" />
          </div>
          <div class="mb-2">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Default: student123" />
          </div>
          <div class="mb-2">
            <label class="form-label">Roll No</label>
            <input type="text" name="roll_no" class="form-control" required />
          </div>
          <div class="mb-2">
            <label class="form-label">Department</label>
            <input type="text" name="department" class="form-control" />
          </div>
          <div class="mb-2">
            <label class="form-label">Year</label>
            <input type="text" name="year" class="form-control" placeholder="e.g. 2nd Year" />
          </div>
          <div class="mb-2">
            <label class="form-label">Address</label>
            <textarea name="address" class="form-control" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">Add Student</button>
        </div>
      </form>
    </div>
  </div>

   <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
