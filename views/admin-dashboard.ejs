<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <!-- Top Navbar -->
  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <!-- Sidebar -->
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link active" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <!-- Main content -->
    <div class="main-content flex-grow-1">
      <h3 class="mb-1">Welcome back, <%= user.name %> 👋</h3>
      <p class="text-muted">Here's what's happening across the bus fleet today.</p>

      <div class="row g-3 mt-2">
        <div class="col-md-4 col-lg-2-4">
          <div class="stat-card bg-c1">
            <i class="bi bi-bus-front-fill fs-3"></i>
            <h2><%= stats.totalBuses %></h2>
            <div>Total Buses</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card bg-c2">
            <i class="bi bi-people-fill fs-3"></i>
            <h2><%= stats.totalStudents %></h2>
            <div>Total Students</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card bg-c5">
            <i class="bi bi-person-badge-fill fs-3"></i>
            <h2><%= stats.totalDrivers %></h2>
            <div>Total Drivers</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card bg-c3">
            <i class="bi bi-envelope-paper-fill fs-3"></i>
            <h2><%= stats.pendingRequests %></h2>
            <div>Pending Requests</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card bg-c4">
            <i class="bi bi-cash-coin fs-3"></i>
            <h2><%= stats.unpaidFees %></h2>
            <div>Unpaid Fees</div>
          </div>
        </div>
      </div>

      <div class="row mt-4 g-3">
        <div class="col-md-6">
          <div class="card p-4">
            <h5><i class="bi bi-lightning-charge-fill text-warning"></i> Quick Actions</h5>
            <div class="d-grid gap-2 mt-3">
              <a href="/admin/buses" class="btn btn-outline-primary"><i class="bi bi-plus-circle"></i> Add / Manage Bus</a>
              <a href="/admin/students" class="btn btn-outline-success"><i class="bi bi-person-plus"></i> Add / Manage Student</a>
              <a href="/admin/assign-bus" class="btn btn-outline-secondary"><i class="bi bi-signpost-split"></i> Assign Bus &amp; Driver</a>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card p-4">
            <h5><i class="bi bi-info-circle-fill text-primary"></i> System Overview</h5>
            <p class="text-muted mt-3 mb-0">
              Use the sidebar to manage buses, students, driver assignments, transport requests
              and fee records for the entire college transport system.
            </p>
          </div>
        </div>
      </div>
         <%- include('footer') %>
      
    </div>
  </div>
      
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
  
</body>
</html>
