<%- include('../partials/header', {
  pageTitle: 'Manage Drivers',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'drivers'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'Manage Drivers'
  }) %>

  <div class="app-main">
    <main class="main-content">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>
          <i class="bi bi-person-badge-fill"></i>
          Manage Drivers
        </h3>

        <button
          class="btn btn-primary"
          data-bs-toggle="modal"
          data-bs-target="#addDriverModal">

          <i class="bi bi-person-plus"></i>
          Add Driver
        </button>
      </div>

      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Assigned Bus</th>
                <th>Route</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>

            <tbody>

              <% if (drivers.length === 0) { %>

              <tr>
                <td colspan="8" class="text-center text-muted py-3">
                  No drivers added yet.
                </td>
              </tr>

              <% } %>

              <% drivers.forEach((d, i) => { %>

              <tr>
                <td><%= i + 1 %></td>
                <td><%= d.name %></td>
                <td><%= d.email %></td>
                <td><%= d.phone || '—' %></td>
                <td><%= d.bus_number || '—' %></td>
                <td><%= d.route_name || '—' %></td>
                <td>
                  <span class="badge <%= d.bus_status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                    <%= d.bus_status || 'unassigned' %>
                  </span>
                </td>

                <td class="text-end">

                  <button
                    class="btn btn-sm btn-outline-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#editDriverModal<%= d.id %>">

                    <i class="bi bi-pencil-square"></i>
                  </button>

                  <form
                    action="/admin/drivers/<%= d.id %>?_method=DELETE"
                    method="POST"
                    class="d-inline confirm-delete">

                    <button class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>

                  </form>

                </td>
              </tr>

              <!-- Edit Modal -->

              <div
                class="modal fade"
                id="editDriverModal<%= d.id %>"
                tabindex="-1">

                <div class="modal-dialog">

                  <form
                    action="/admin/drivers/<%= d.id %>?_method=PUT"
                    method="POST"
                    class="modal-content">

                    <div class="modal-header">
                      <h5 class="modal-title">
                        Edit Driver
                      </h5>

                      <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                      </button>
                    </div>

                    <div class="modal-body">

                      <div class="mb-2">
                        <label class="form-label">Full Name</label>
                        <input
                          type="text"
                          name="name"
                          class="form-control"
                          value="<%= d.name %>"
                          required>
                      </div>

                      <div class="mb-2">
                        <label class="form-label">Email</label>
                        <input
                          type="email"
                          name="email"
                          class="form-control"
                          value="<%= d.email %>"
                          required>
                      </div>

                      <div class="mb-2">
                        <label class="form-label">Phone</label>
                        <input
                          type="text"
                          name="phone"
                          class="form-control"
                          value="<%= d.phone || '' %>">
                      </div>

                      <div class="mb-2">
                        <label class="form-label">Assign Bus</label>
                        <select name="bus_id" class="form-select">
                          <option value="">-- Unassigned --</option>
                          <% buses.forEach(b => { %>
                            <option
                              value="<%= b.id %>"
                              <%= (d.bus_id === b.id) ? 'selected' : '' %>>
                              <%= b.bus_number %> — <%= b.route_name %>
                            </option>
                          <% }) %>
                        </select>
                      </div>

                    </div>

                    <div class="modal-footer">
                      <button
                        type="submit"
                        class="btn btn-primary">
                        Save Changes
                      </button>
                    </div>

                  </form>
                </div>
              </div>

              <% }) %>

            </tbody>
          </table>
        </div>
      </div>

    </main>

    <%- include('../partials/footer') %>

  </div>
</div>

<!-- Add Driver Modal -->

<div
  class="modal fade"
  id="addDriverModal"
  tabindex="-1">

  <div class="modal-dialog">

    <form
      action="/admin/drivers"
      method="POST"
      class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">
          Add New Driver
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal">
        </button>
      </div>

      <div class="modal-body">

        <div class="mb-2">
          <label class="form-label">Full Name</label>
          <input
            type="text"
            name="name"
            class="form-control"
            required>
        </div>

        <div class="mb-2">
          <label class="form-label">Email</label>
          <input
            type="email"
            name="email"
            class="form-control"
            required>
        </div>

        <div class="mb-2">
          <label class="form-label">Phone</label>
          <input
            type="text"
            name="phone"
            class="form-control">
        </div>

        <div class="mb-2">
          <label class="form-label">Password</label>
          <input
            type="password"
            name="password"
            class="form-control"
            placeholder="Default: driver123">
        </div>

        <div class="mb-2">
          <label class="form-label">Assign Bus</label>
          <select name="bus_id" class="form-select">
            <option value="">-- Unassigned --</option>
            <% buses.forEach(b => { %>
              <option value="<%= b.id %>">
                <%= b.bus_number %> — <%= b.route_name %>
              </option>
            <% }) %>
          </select>
        </div>

      </div>

      <div class="modal-footer">
        <button
          type="submit"
          class="btn btn-primary">
          Add Driver
        </button>
      </div>

    </form>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="../public/js/script.js"></script>

</body>
</html>
