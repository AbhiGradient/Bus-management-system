<%- include('../partials/header', {
  pageTitle: 'My Profile',
  pageCss: []
}) %>

<div class="app-shell">

  <%- include('../partials/sidebar', {
    currentPage: 'profile'
  }) %>

  <%- include('../partials/navbar', {
    pageLabel: 'My Profile'
  }) %>

  <div class="app-main">

    <main class="main-content">
    
      <h3 class="mb-3"><i class="bi bi-person-badge"></i> My Profile</h3>

      <% if (message) { %>
        <div class="alert alert-success auto-alert"><%= message %></div>
      <% } %>

      <div class="row">
        <div class="col-lg-7">
          <div class="card p-4">
            <form action="/admin/profile?_method=PUT" method="POST">
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= profile.name %>" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Email (read-only)</label>
                <input type="email" class="form-control" value="<%= profile.email %>" disabled />
              </div>
              <div class="mb-3">
                <label class="form-label">Phone</label>
                <input type="text" name="phone" class="form-control" value="<%= profile.phone || '' %>" />
              </div>

              <% if (user.role === 'student') { %>
                <div class="mb-3">
                  <label class="form-label">Roll No (read-only)</label>
                  <input type="text" class="form-control" value="<%= profile.roll_no || '' %>" disabled />
                </div>
                <div class="mb-3">
                  <label class="form-label">Department</label>
                  <input type="text" name="department" class="form-control" value="<%= profile.department || '' %>" />
                </div>
                <div class="mb-3">
                  <label class="form-label">Year</label>
                  <input type="text" name="year" class="form-control" value="<%= profile.year || '' %>" />
                </div>
                <div class="mb-3">
                  <label class="form-label">Address</label>
                  <textarea name="address" class="form-control" rows="2"><%= profile.address || '' %></textarea>
                </div>
              <% } %>

              <div class="mb-3">
                <label class="form-label">New Password <small class="text-muted">(leave blank to keep current)</small></label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" />
              </div>

              <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Save Changes</button>
            </form>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card p-4 text-center">
            <i class="bi bi-person-circle" style="font-size: 5rem; color: #1d4ed8;"></i>
            <h5 class="mt-2 mb-0"><%= profile.name %></h5>
            <span class="text-muted text-capitalize"><%= user.role %></span>
          </div>
        </div>
      </div>

       
    </div>
  </main>

    
  </div> <!-- /.app-main -->
<%- include('../partials/footer') %>

</div> <!-- /.app-shell -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>