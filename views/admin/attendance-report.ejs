<%- include('partials/header', {
    pageTitle: 'Attendance Report',
    pageCss: ['attendance-report']
}) %>

<div class="app-shell">

    <%- include('partials/sidebar', {
        currentPage: 'attendance-report'
    }) %>

    <div class="app-main">

        <%- include('partials/navbar', {
            pageLabel: 'Attendance Report'
        }) %>

        <main class="page-content">

            <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                <div>
                    <h1 class="page-title">Attendance Report</h1>
                    <p class="text-muted mb-0">
                        View attendance records, filter results and monitor student attendance.
                    </p>
                </div>

                <button class="btn btn-outline-secondary"
                        onclick="window.print()">
                    Print / Export
                </button>
            </div>

            <!-- Statistics -->

            <div class="row g-3 mb-4">

                <div class="col-lg-3 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <h3><%= stats.total %></h3>
                            <p class="mb-0 text-muted">Total Records</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <h3 class="text-success"><%= stats.present %></h3>
                            <p class="mb-0 text-muted">Present</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <h3 class="text-danger"><%= stats.absent %></h3>
                            <p class="mb-0 text-muted">Absent</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <h3 class="text-primary"><%= stats.rate %>%</h3>
                            <p class="mb-0 text-muted">Attendance Rate</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Filters -->

            <div class="card shadow-sm mb-4">

                <div class="card-body">

                    <form
                        method="GET"
                        action="/admin/attendance-report"
                        class="row g-3 align-items-end">

                        <div class="col-md-3">
                            <label class="form-label">
                                Date
                            </label>

                            <input
                                type="date"
                                name="date"
                                class="form-control"
                                value="<%= filters.date || '' %>">
                        </div>

                        <div class="col-md-3">

                            <label class="form-label">
                                Bus
                            </label>

                            <select
                                name="bus_id"
                                class="form-select">

                                <option value="">
                                    All Buses
                                </option>

                                <% buses.forEach(b => { %>

                                    <option
                                        value="<%= b.id %>"
                                        <%= String(filters.bus_id)===String(b.id) ? 'selected' : '' %>>

                                        <%= b.bus_number %>

                                    </option>

                                <% }) %>

                            </select>

                        </div>

                        <div class="col-md-3">

                            <label class="form-label">
                                Status
                            </label>

                            <select
                                name="status"
                                class="form-select">

                                <option value="">
                                    All
                                </option>

                                <option
                                    value="present"
                                    <%= filters.status==='present' ? 'selected' : '' %>>
                                    Present
                                </option>

                                <option
                                    value="absent"
                                    <%= filters.status==='absent' ? 'selected' : '' %>>
                                    Absent
                                </option>

                            </select>

                        </div>

                        <div class="col-md-3 d-flex gap-2">

                            <button
                                class="btn btn-primary flex-fill"
                                type="submit">

                                Apply Filters

                            </button>

                            <a
                                href="/admin/attendance-report"
                                class="btn btn-outline-secondary">

                                Reset

                            </a>

                        </div>

                    </form>

                </div>

            </div>

            <!-- Attendance Table -->

            <div class="card shadow-sm">

                <div class="card-header">
                    <h5 class="mb-0">
                        Attendance Records
                    </h5>
                </div>

                <div class="card-body p-0">

                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead>

                                <tr>
                                    <th>#</th>
                                    <th>Student</th>
                                    <th>Roll No</th>
                                    <th>Bus</th>
                                    <th>Date</th>
                                    <th>Time In</th>
                                    <th>Status</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% if (!records || records.length === 0) { %>

                                    <tr>

                                        <td
                                            colspan="7"
                                            class="text-center py-5 text-muted">

                                            No attendance records found.

                                        </td>

                                    </tr>

                                <% } %>

                                <% records.forEach((r,i)=>{ %>

                                    <tr>

                                        <td><%= i+1 %></td>

                                        <td><%= r.student_name %></td>

                                        <td><%= r.roll_no %></td>

                                        <td><%= r.bus_number %></td>

                                        <td>

                                            <%= new Date(r.date).toLocaleDateString() %>

                                        </td>

                                        <td>

                                            <%= r.time_in || '—' %>

                                        </td>

                                        <td>

                                            <span class="badge <%= r.status==='present' ? 'bg-success' : 'bg-danger' %>">

                                                <%= r.status %>

                                            </span>

                                        </td>

                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </main>

        <%- include('partials/footer') %>

    </div>

</div>

<script src="/js/script.js"></script>

</body>
</html>