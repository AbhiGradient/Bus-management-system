<!--
  attendance-report.ejs  (Admin)
  ------------------------------------------------------------
  Expected route: GET /admin/attendance-report  ->  routes/qr.js
  Expected locals:
    user    -> req.session.user
    buses   -> [{ id, bus_number }]                for the filter dropdown
    filters -> { date: 'YYYY-MM-DD'|'', bus_id: ''|'<id>', status: ''|'present'|'absent' }
    stats   -> { total, present, absent, rate }     rate = 0-100 attendance %
    records -> [{
                 id, student_name, roll_no, bus_number,
                 date, time_in, status  // 'present' | 'absent'
               }]

  This assumes a future `attendance` table, e.g.:
    CREATE TABLE attendance (
      id INT AUTO_INCREMENT PRIMARY KEY,
      student_id INT NOT NULL,
      bus_id INT NOT NULL,
      date DATE NOT NULL,
      time_in TIME DEFAULT NULL,
      status ENUM('present','absent') DEFAULT 'present',
      FOREIGN KEY (student_id) REFERENCES students(id) ON DELETE CASCADE,
      FOREIGN KEY (bus_id) REFERENCES buses(id) ON DELETE CASCADE
    );
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Attendance Report | Smart College Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/admin/dashboard"><i class="bi bi-bus-front"></i> College Bus <span>Admin</span></a>
    <div class="d-flex align-items-center text-white">
      <span class="me-3"><i class="bi bi-person-circle"></i> <%= user.name %></span>
      <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </nav>

  <div class="d-flex">
    <div class="sidebar" style="width: 230px;">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/buses"><i class="bi bi-bus-front-fill"></i> Manage Buses</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/students"><i class="bi bi-people-fill"></i> Manage Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/assign-bus"><i class="bi bi-signpost-split"></i> Assign Bus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/requests"><i class="bi bi-envelope-paper"></i> Requests</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/fees"><i class="bi bi-cash-coin"></i> Fees</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/qr-generator"><i class="bi bi-qr-code"></i> QR Generator</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/attendance-report"><i class="bi bi-clipboard-data"></i> Attendance Report</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/profile"><i class="bi bi-person-badge"></i> Profile</a></li>
      </ul>
    </div>

    <div class="main-content flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h3 class="mb-0"><i class="bi bi-clipboard-data"></i> Attendance Report</h3>
        <button class="btn btn-outline-secondary btn-sm no-print" onclick="window.print()">
          <i class="bi bi-printer"></i> Print / Export
        </button>
      </div>

      <!-- Stat cards -->
      <div class="row g-3 mb-1">
        <div class="col-md-3">
          <div class="stat-card bg-c3">
            <i class="bi bi-people-fill fs-3"></i>
            <h2><%= stats.total %></h2>
            <div>Total Records</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card bg-c5">
            <i class="bi bi-check-circle-fill fs-3"></i>
            <h2><%= stats.present %></h2>
            <div>Present</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card bg-c4">
            <i class="bi bi-x-circle-fill fs-3"></i>
            <h2><%= stats.absent %></h2>
            <div>Absent</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card bg-c2">
            <i class="bi bi-graph-up fs-3"></i>
            <h2><%= stats.rate %>%</h2>
            <div>Attendance Rate</div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="report-filter-bar mt-4 mb-3 no-print">
        <form method="GET" action="/admin/attendance-report" class="row g-2 align-items-end">
          <div class="col-sm-3">
            <label class="form-label mb-1">Date</label>
            <input type="date" name="date" class="form-control form-control-sm" value="<%= filters.date || '' %>">
          </div>
          <div class="col-sm-3">
            <label class="form-label mb-1">Bus</label>
            <select name="bus_id" class="form-select form-select-sm">
              <option value="">All Buses</option>
              <% buses.forEach(b => { %>
                <option value="<%= b.id %>" <%= String(filters.bus_id) === String(b.id) ? 'selected' : '' %>><%= b.bus_number %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-sm-3">
            <label class="form-label mb-1">Status</label>
            <select name="status" class="form-select form-select-sm">
              <option value="">All</option>
              <option value="present" <%= filters.status === 'present' ? 'selected' : '' %>>Present</option>
              <option value="absent" <%= filters.status === 'absent' ? 'selected' : '' %>>Absent</option>
            </select>
          </div>
          <div class="col-sm-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
              <i class="bi bi-funnel"></i> Apply
            </button>
            <a href="/admin/attendance-report" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-arrow-counterclockwise"></i>
            </a>
          </div>
        </form>
      </div>

      <!-- Records table -->
      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Student</th>
                <th>Roll No</th>
                <th>Bus</th>
                <th>Date</th>
                <th>Time In</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (!records || records.length === 0) { %>
                <tr><td colspan="7" class="text-center text-muted py-3">No attendance records found for the selected filters.</td></tr>
              <% } %>
              <% records.forEach((r, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= r.student_name %></td>
                  <td><%= r.roll_no %></td>
                  <td><%= r.bus_number %></td>
                  <td><%= new Date(r.date).toLocaleDateString() %></td>
                  <td><%= r.time_in || '—' %></td>
                  <td>
                    <span class="badge badge-status <%= r.status === 'present' ? 'bg-success' : 'bg-danger' %>">
                      <%= r.status %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>